@model Viatour_Travel.Dtos.TourDtos.GetTourDetailDto
@using Microsoft.Extensions.Localization
@using Viatour_Travel.Dtos.TourImageDtos
@inject IStringLocalizer<Viatour_Travel.SharedResource> Localizer

@{

    ViewData["Title"] = Localizer["TourDetail"];
    Layout = "~/Views/Shared/_TourLayout.cshtml";

    var images = Model?.TourImages ?? new List<ResultTourImageDto>();
    var plans = (Model?.TourPlans ?? new List<Viatour_Travel.Dtos.TourDtos.TourPlanDto>())
        .OrderBy(x => x.DayNumber)
        .ToList();

    var reviews = Model?.Reviews ?? new List<Viatour_Travel.Dtos.ReviewDtos.ResultReviewByTourIdDto>();

    var firstTourImage = images.FirstOrDefault()?.ImageUrl;

    var coverImage = !string.IsNullOrWhiteSpace(firstTourImage)
        ? firstTourImage
        : !string.IsNullOrWhiteSpace(Model?.CoverImageUrl)
            ? Model.CoverImageUrl
            : "/vitour/assets/images/travel-list/2.jpg";

    var mapImage = !string.IsNullOrWhiteSpace(Model?.MapLocationImageUrl)
        ? Model.MapLocationImageUrl
        : coverImage;

    var activeReviews = reviews
        .Where(x => x.Status)
        .OrderByDescending(x => x.ReviewDate)
        .ToList();

    var totalReview = activeReviews.Count;
    var avgScore = totalReview > 0 ? activeReviews.Average(x => x.Score) : 0;
    var roundedAvgScore = (int)Math.Round(avgScore);

    string GetPlanTitle(Viatour_Travel.Dtos.TourDtos.TourPlanDto plan)
    {
        if (!string.IsNullOrWhiteSpace(plan.Title))
            return plan.Title;

        return $"{plan.DayNumber}. {Localizer["Day"]}";
    }
}

@if (Model == null)
{
    <section class="tour-single">
        <div class="tf-container">
            <div class="content-card">
                <h2>@Localizer["TourNotFound"]</h2>
            </div>
        </div>
    </section>
}
else
{
    <section class="tour-single style-modern">
        <div class="tf-container">

            <div class="tour-hero-banner mb-40" style="background-image:url('@coverImage');">
                <div class="tour-hero-overlay"></div>

                <div class="tour-hero-content">
                    <div class="row align-items-end">
                        <div class="col-lg-8">
                            <div class="tour-detail-heading hero-text">
                                <span class="feature">
                                    @(!string.IsNullOrWhiteSpace(Model.Badge) ? Model.Badge : Localizer["Featured"])
                                </span>

                                <h1 class="title">@Model.TourTitle</h1>

                                <ul class="flex-three list-wrap-heading">
                                    <li class="flex-three">
                                        <i class="icon-time-left"></i>
                                        <span>@Model.DayCount @Localizer["Day"]</span>
                                    </li>
                                    <li class="flex-three">
                                        <i class="icon-user"></i>
                                        <span>@Localizer["Maximum"] @Model.Capacity @Localizer["Person"]</span>
                                    </li>
                                    <li class="flex-three">
                                        <i class="icon-18"></i>
                                        <span>@Model.Location</span>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <div class="col-lg-4">
                            <div class="tour-detail-price-box hero-price-box">
                                <div class="start mb-10">
                                    @for (int i = 0; i < 5; i++)
                                    {
                                        if (i < roundedAvgScore)
                                        {
                                            <i class="icon-Star"></i>
                                        }
                                        else
                                        {
                                            <i class="icon-Star" style="opacity:.35"></i>
                                        }
                                    }
                                    <span class="review">(@totalReview @Localizer["Review"])</span>
                                </div>

                                <p class="price-sale text-main">
                                    $@Model.Price
                                    <span class="price">$@Model.Price</span>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

           
            <div class="row">
                <div class="col-lg-12">
                    <ul class="nav tab-tour-single modern-tabs" id="pills-tab" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active"
                                    id="pills-information-tab"
                                    data-bs-toggle="pill"
                                    data-bs-target="#pills-information"
                                    type="button"
                                    role="tab">
                                <i class="icon-Vector-51"></i> @Localizer["Overview"]
                            </button>
                        </li>

                        <li class="nav-item" role="presentation">
                            <button class="nav-link"
                                    id="pills-tour-planing-tab"
                                    data-bs-toggle="pill"
                                    data-bs-target="#pills-tour-planing"
                                    type="button"
                                    role="tab">
                                <i class="icon-destination-2-1"></i> @Localizer["Program"]
                            </button>
                        </li>

                        <li class="nav-item" role="presentation">
                            <button class="nav-link"
                                    id="pills-shot-gallery-tab"
                                    data-bs-toggle="pill"
                                    data-bs-target="#pills-shot-gallery"
                                    type="button"
                                    role="tab">
                                <i class="icon-image-gallery-1"></i> @Localizer["Gallery"]
                            </button>
                        </li>

                        <li class="nav-item" role="presentation">
                            <button class="nav-link"
                                    id="pills-location-share-tab"
                                    data-bs-toggle="pill"
                                    data-bs-target="#pills-location-share"
                                    type="button"
                                    role="tab">
                                <i class="icon-map-1"></i> @Localizer["Map"]
                            </button>
                        </li>

                        <li class="nav-item" role="presentation">
                            <button class="nav-link"
                                    id="pills-reviews-tab"
                                    data-bs-toggle="pill"
                                    data-bs-target="#pills-reviews"
                                    type="button"
                                    role="tab">
                                <i class="icon-favourite-1"></i> @Localizer["Reviews"]
                            </button>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="row pd-main">
                <div class="col-lg-8">
                    <div class="tab-content" id="pills-tabContent">

                        <!-- Overview -->
                        <div class="tab-pane fade show active" id="pills-information" role="tabpanel">
                            <div class="content-card mb-30">
                                <h3 class="section-title">@Localizer["Description"]</h3>
                                <p class="des">@Model.TourDescription</p>
                            </div>

                            <div class="content-card mb-30">
                                <h3 class="section-title">@Localizer["TourInformation"]</h3>

                                <div class="expect flex-three">
                                    <span>@Localizer["Location"]</span>
                                    <p>@Model.Location</p>
                                </div>

                                <div class="expect flex-three">
                                    <span>@Localizer["TourDuration"]</span>
                                    <p>@Model.DayCount @Localizer["Day"]</p>
                                </div>

                                <div class="expect flex-three">
                                    <span>@Localizer["MaximumCapacity"]</span>
                                    <p>@Model.Capacity @Localizer["Person"]</p>
                                </div>

                                <div class="expect flex-three">
                                    <span>@Localizer["Price"]</span>
                                    <p>$@Model.Price</p>
                                </div>
                            </div>
                        </div>

                        <!-- Program -->
                        <div class="tab-pane fade" id="pills-tour-planing" role="tabpanel">
                            <div class="content-card">
                                <h3 class="section-title">@Localizer["DailyTourProgram"]</h3>

                                @if (plans.Any())
                                {
                                    <div class="custom-tour-accordion">
                                        @for (int i = 0; i < plans.Count; i++)
                                        {
                                            var item = plans[i];
                                            var collapseId = $"planCollapse_{i}";
                                            var headingId = $"planHeading_{i}";
                                            var isFirst = i == 0;
                                            var planTitle = GetPlanTitle(item);

                                            <div class="tour-accordion-item">
                                                <div class="tour-accordion-header @(isFirst ? "active" : "")"
                                                     data-bs-toggle="collapse"
                                                     data-bs-target="#@collapseId"
                                                     aria-expanded="@(isFirst.ToString().ToLower())"
                                                     aria-controls="@collapseId"
                                                     id="@headingId">

                                                    <div class="tour-day-badge">
                                                        @item.DayNumber @Localizer["Day"]
                                                    </div>

                                                    <div class="tour-day-title">
                                                        @planTitle
                                                    </div>

                                                    <div class="tour-day-icon">
                                                        <i class="icon-29"></i>
                                                    </div>
                                                </div>

                                                <div id="@collapseId"
                                                     class="collapse @(isFirst ? "show" : "")"
                                                     aria-labelledby="@headingId">
                                                    <div class="tour-accordion-body">
                                                        @item.Description
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="des">@Localizer["NoPlanAddedForThisTourYet"]</p>
                                }
                            </div>
                        </div>

                        <!-- Gallery -->
                        <!-- Gallery -->
                        <div class="tab-pane fade" id="pills-shot-gallery" role="tabpanel">
                            <div class="content-card">
                                <h3 class="section-title">@Localizer["Gallery"]</h3>

                                @if (images.Any())
                                {
                                    <div class="gallery-content-tour custom-gallery-grid">
                                        @foreach (var item in images)
                                        {
                                            <div class="image gallery-click-item"
                                                 data-image="@item.ImageUrl">
                                                <img src="@item.ImageUrl"
                                                     alt="@Localizer["TourGalleryImage"]"
                                                     class="gallery-item-img">
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="des">@Localizer["NoGalleryImagesAddedForThisTourYet"]</p>
                                }
                            </div>
                        </div>
                        <!-- Map -->
                        <div class="tab-pane fade" id="pills-location-share" role="tabpanel">
                            <div class="content-card map-card-modern">
                                <div class="map-card-header">
                                    <div>
                                        <span class="map-badge">AI Illustrated Route</span>
                                        <h3 class="section-title mb-8">@Localizer["MapLocation"]</h3>
                                        <p class="map-subtitle">
                                            @Model.TourTitle - @Model.Location
                                        </p>
                                    </div>
                                </div>

                                <div class="tour-map-image-wrapper">
                                    <img src="@mapImage"
                                         alt="@($"{Model.TourTitle} Map")"
                                         class="tour-map-image"
                                         onerror="this.onerror=null;this.src='@coverImage';" />
                                </div>

                                <div class="map-info-box">
                                    <div class="map-info-item">
                                        <span class="map-info-label">@Localizer["Location"]</span>
                                        <strong>@Model.Location</strong>
                                    </div>

                                    <div class="map-info-item">
                                        <span class="map-info-label">@Localizer["TourDuration"]</span>
                                        <strong>@Model.DayCount @Localizer["Day"]</strong>
                                    </div>

                                    <div class="map-info-item">
                                        <span class="map-info-label">@Localizer["MaximumCapacity"]</span>
                                        <strong>@Model.Capacity @Localizer["Person"]</strong>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Reviews -->
                        <!-- Reviews -->
                        <div class="tab-pane fade" id="pills-reviews" role="tabpanel">
                            <div class="content-card review-card-modern">
                                <div class="review-header-modern">
                                    <div>
                                        <h3 class="section-title mb-8">@Localizer["Reviews"]</h3>
                                        <p class="review-subtitle-modern">
                                            Read approved guest reviews for this tour and share your own experience.
                                        </p>
                                    </div>

                                    <a href="/Review/CreateReview?tourId=@Model.TourId" class="write-review-btn">
                                        <i class="icon-Vector-51"></i> Write a Review
                                    </a>
                                </div>

                                <div class="review-summary-box">
                                    <div class="review-score-main">
                                        <div class="score-circle">
                                            <span>@avgScore.ToString("0.0")</span>
                                        </div>
                                        <div>
                                            <h5 class="score-title">Overall Rating</h5>
                                            <div class="start mb-6">
                                                @for (int i = 0; i < 5; i++)
                                                {
                                                    if (i < roundedAvgScore)
                                                    {
                                                        <i class="icon-Star"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="icon-Star" style="opacity:.25"></i>
                                                    }
                                                }
                                            </div>
                                            <p class="score-meta">
                                                @totalReview approved review@(totalReview == 1 ? "" : "s")
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                <div class="review-list-modern">
                                    @if (activeReviews.Any())
                                    {
                                        @foreach (var item in activeReviews)
                                        {
                                            var initials = string.Join("",
                                            item.NameSurname.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                                            .Take(2)
                                            .Select(w => w[0].ToString().ToUpper()));

                                            <div class="review-item-modern">
                                                <div class="review-user-side">
                                                    <div class="review-avatar-modern">@initials</div>
                                                </div>

                                                <div class="review-content-modern">
                                                    <div class="review-top-line">
                                                        <div>
                                                            <h6 class="review-user-name">@item.NameSurname</h6>
                                                            <span class="review-date-modern">@item.ReviewDate.ToString("dd MMM yyyy")</span>
                                                        </div>

                                                        <div class="review-stars-modern">
                                                            @for (int i = 0; i < 5; i++)
                                                            {
                                                                if (i < item.Score)
                                                                {
                                                                    <i class="icon-Star"></i>
                                                                }
                                                                else
                                                                {
                                                                    <i class="icon-Star" style="opacity:.25"></i>
                                                                }
                                                            }
                                                            <span class="review-score-number">@item.Score/5</span>
                                                        </div>
                                                    </div>

                                                    <p class="review-text-modern">
                                                        @item.Detail
                                                    </p>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="empty-review-box">
                                            <div class="empty-review-icon">
                                                <i class="icon-favourite-1"></i>
                                            </div>
                                            <h5>No approved reviews yet</h5>
                                            <p>
                                                This tour does not have any approved reviews yet. Be the first one to share your experience.
                                            </p>
                                            <a href="/Review/CreateReview?tourId=@Model.TourId" class="write-review-btn">
                                                Write the First Review
                                            </a>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="side-bar-right sticky-sidebar">
                        <div class="sidebar-widget modern-book-widget">
                            <h6 class="block-heading">@Localizer["BookThisTour"]</h6>

                            <div class="tour-book-summary">
                                <div class="summary-price">
                                    <span class="label">@Localizer["StartingPrice"]</span>
                                    <h3>$@Model.Price</h3>
                                </div>

                                <ul class="summary-list">
                                    <li>
                                        <span>@Localizer["Duration"]</span>
                                        <strong>@Model.DayCount @Localizer["Day"]</strong>
                                    </li>
                                    <li>
                                        <span>@Localizer["Capacity"]</span>
                                        <strong>@Model.Capacity @Localizer["Person"]</strong>
                                    </li>
                                    <li>
                                        <span>@Localizer["Location"]</span>
                                        <strong>@Model.Location</strong>
                                    </li>
                                </ul>

                                <a href="/Reservation/CreateReservation?tourId=@Model.TourId&tourTitle=@Model.TourTitle&tourImageUrl=@coverImage"
                                   class="booking-btn">
                                    @Localizer["MakeReservation"]
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </section>
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="reservation-success-modal" id="reservationSuccessModal">
            <div class="reservation-success-backdrop"></div>

            <div class="reservation-success-dialog">
                <button type="button" class="reservation-success-close" id="reservationSuccessClose">&times;</button>

                <div class="reservation-success-icon">
                    <i class="icon-Vector-51"></i>
                </div>

                <h3 class="reservation-success-title">Reservation Request Received</h3>

                <p class="reservation-success-text">
                    @TempData["SuccessMessage"]
                </p>

                <button type="button" class="reservation-success-btn" id="reservationSuccessOk">
                    Okay
                </button>
            </div>
        </div>
    }
    <div class="gallery-lightbox" id="galleryLightbox">
        <span class="gallery-lightbox-close" id="galleryLightboxClose">&times;</span>
        <img id="galleryLightboxImage" class="gallery-lightbox-image" src="" alt="Preview">
    </div>
}

<style>
    .reservation-success-modal {
        position: fixed;
        inset: 0;
        z-index: 99999;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .reservation-success-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(15, 23, 42, 0.55);
        backdrop-filter: blur(4px);
    }

    .reservation-success-dialog {
        position: relative;
        z-index: 2;
        width: 100%;
        max-width: 520px;
        background: #fff;
        border-radius: 24px;
        padding: 34px 28px 28px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.18);
        text-align: center;
        animation: reservationModalIn .28s ease;
    }

    @@keyframes reservationModalIn {
        from

    {
        opacity: 0;
        transform: translateY(14px) scale(.96);
    }

    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }

    }

    .reservation-success-close {
        position: absolute;
        top: 14px;
        right: 16px;
        border: none;
        background: transparent;
        font-size: 32px;
        line-height: 1;
        color: #94a3b8;
        cursor: pointer;
    }

        .reservation-success-close:hover {
            color: #0f172a;
        }

    .reservation-success-icon {
        width: 82px;
        height: 82px;
        border-radius: 50%;
        background: linear-gradient(135deg, #10b981, #14b8a6);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 18px;
        font-size: 30px;
        box-shadow: 0 16px 35px rgba(16,185,129,0.28);
    }

    .reservation-success-title {
        font-size: 28px;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 12px;
    }

    .reservation-success-text {
        font-size: 15px;
        line-height: 1.8;
        color: #64748b;
        margin: 0 0 24px;
    }

    .reservation-success-btn {
        min-width: 160px;
        border: none;
        border-radius: 14px;
        background: linear-gradient(135deg, #10b981, #14b8a6);
        color: #fff;
        font-weight: 800;
        padding: 14px 24px;
        cursor: pointer;
        box-shadow: 0 14px 28px rgba(16,185,129,0.24);
        transition: .2s ease;
    }

        .reservation-success-btn:hover {
            transform: translateY(-2px);
        }

    @@media (max-width: 767px) {
        .reservation-success-dialog

    {
        padding: 28px 20px 22px;
        border-radius: 20px;
    }

    .reservation-success-title {
        font-size: 22px;
    }

    .reservation-success-text {
        font-size: 14px;
    }

    }
    .gallery-click-item {
        cursor: pointer;
    }

    .gallery-lightbox {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.88);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        padding: 30px;
    }

        .gallery-lightbox.show {
            display: flex;
        }

    .gallery-lightbox-image {
        max-width: 92vw;
        max-height: 88vh;
        object-fit: contain;
        border-radius: 18px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.35);
        background: #fff;
    }

    .gallery-lightbox-close {
        position: absolute;
        top: 24px;
        right: 30px;
        font-size: 42px;
        line-height: 1;
        color: #fff;
        cursor: pointer;
        font-weight: 300;
    }

        .gallery-lightbox-close:hover {
            opacity: .8;
        }
    .review-card-modern {
        padding: 30px;
    }

    .review-header-modern {
        display: flex;
        justify-content: space-between;
        align-items: start;
        gap: 20px;
        flex-wrap: wrap;
        margin-bottom: 26px;
    }

    .review-subtitle-modern {
        color: #6b7280;
        margin: 0;
        font-size: 14px;
        line-height: 1.8;
    }

    .write-review-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #10b981;
        color: #fff;
        border-radius: 12px;
        padding: 12px 18px;
        font-weight: 700;
        transition: .25s ease;
    }

        .write-review-btn:hover {
            background: #059669;
            color: #fff;
        }

    .review-summary-box {
        background: #f8fafc;
        border: 1px solid #eef2f7;
        border-radius: 20px;
        padding: 20px 22px;
        margin-bottom: 26px;
    }

    .review-score-main {
        display: flex;
        align-items: center;
        gap: 18px;
        flex-wrap: wrap;
    }

    .score-circle {
        width: 84px;
        height: 84px;
        border-radius: 50%;
        background: linear-gradient(135deg, #10b981, #14b8a6);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
        font-weight: 800;
        box-shadow: 0 12px 24px rgba(16,185,129,0.25);
    }

    .score-title {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .score-meta {
        margin: 0;
        font-size: 14px;
        color: #6b7280;
    }

    .mb-6 {
        margin-bottom: 6px;
    }

    .review-list-modern {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .review-item-modern {
        display: flex;
        gap: 16px;
        border: 1px solid #eef2f7;
        border-radius: 18px;
        padding: 18px;
        background: #fff;
        transition: .25s ease;
    }

        .review-item-modern:hover {
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            transform: translateY(-2px);
        }

    .review-user-side {
        flex-shrink: 0;
    }

    .review-avatar-modern {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #dbeafe;
        color: #1d4ed8;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        font-weight: 800;
    }

    .review-content-modern {
        flex: 1;
    }

    .review-top-line {
        display: flex;
        justify-content: space-between;
        align-items: start;
        gap: 14px;
        margin-bottom: 10px;
        flex-wrap: wrap;
    }

    .review-user-name {
        font-size: 16px;
        font-weight: 700;
        margin: 0 0 4px;
    }

    .review-date-modern {
        font-size: 12px;
        color: #9ca3af;
    }

    .review-stars-modern {
        display: flex;
        align-items: center;
        gap: 3px;
    }

        .review-stars-modern i {
            color: #f59e0b;
        }

    .review-score-number {
        margin-left: 6px;
        font-size: 12px;
        color: #6b7280;
