<script>
    document.addEventListener("DOMContentLoaded", function () {
        const params = new URLSearchParams(window.location.search);
        const tab = params.get("tab");

        if (tab === "reviews") {
            const reviewTabButton = document.getElementById("pills-reviews-tab");
            if (reviewTabButton) {
                reviewTabButton.click();

                const reviewSection = document.getElementById("pills-reviews");
                if (reviewSection) {
                    setTimeout(() => {
                        reviewSection.scrollIntoView({ behavior: "smooth", block: "start" });
                    }, 150);
                }
            }
        }
    });
    document.addEventListener("DOMContentLoaded", function () {
        const lightbox = document.getElementById("galleryLightbox");
        const lightboxImage = document.getElementById("galleryLightboxImage");
        const lightboxClose = document.getElementById("galleryLightboxClose");
        const galleryItems = document.querySelectorAll(".gallery-click-item");

        galleryItems.forEach(item => {
            item.addEventListener("click", function () {
                const imageUrl = this.getAttribute("data-image");
                lightboxImage.src = imageUrl;
                lightbox.classList.add("show");
            });
        });

        lightboxClose.addEventListener("click", function () {
            lightbox.classList.remove("show");
            lightboxImage.src = "";
        });

        lightbox.addEventListener("click", function (e) {
            if (e.target === lightbox) {
                lightbox.classList.remove("show");
                lightboxImage.src = "";
            }
        });

        document.addEventListener("keydown", function (e) {
            if (e.key === "Escape") {
                lightbox.classList.remove("show");
                lightboxImage.src = "";
            }
        });
    });

    document.addEventListener("DOMContentLoaded", function () {
        const successModal = document.getElementById("reservationSuccessModal");
        const successClose = document.getElementById("reservationSuccessClose");
        const successOk = document.getElementById("reservationSuccessOk");

        if (successModal) {
            function closeReservationModal() {
                successModal.style.display = "none";
            }

            successClose?.addEventListener("click", closeReservationModal);
            successOk?.addEventListener("click", closeReservationModal);

            successModal.addEventListener("click", function (e) {
                if (e.target.classList.contains("reservation-success-backdrop")) {
                    closeReservationModal();
                }
            });

            document.addEventListener("keydown", function (e) {
                if (e.key === "Escape") {
                    closeReservationModal();
                }
            });
        }
    });
</script>
