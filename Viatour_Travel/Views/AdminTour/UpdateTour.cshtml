@model Viatour_Travel.Dtos.TourDtos.UpdateTourDto

@{
    ViewData["Title"] = "Update Tour";
    Layout = "~/Views/Shared/_AdminTourLayout.cshtml";
}

@section Styles {
    <style>
        .section-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 28px;
        }

        .page-eyebrow {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--accent);
            margin-bottom: 4px;
        }

        .page-title {
            margin: 0;
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #fff;
            color: var(--text-muted);
            border: 1px solid var(--border);
            padding: 10px 18px;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 13.5px;
            font-weight: 500;
            cursor: pointer;
            transition: background .15s, color .15s, border-color .15s;
            text-decoration: none;
        }

            .btn-back:hover {
                background: var(--surface);
                color: var(--navy);
                border-color: #c4cdd9;
            }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 340px;
            gap: 24px;
            align-items: start;
        }

        @@media (max-width: 1100px) {
            .form-grid {
                grid-template-columns: 1fr;
            }
        }

        .form-card {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 16px;
            box-shadow: var(--shadow-md);
            overflow: hidden;
            margin-bottom: 20px;
        }

            .form-card:last-child {
                margin-bottom: 0;
            }

        .form-card-header {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 18px 24px;
            border-bottom: 1px solid var(--border);
            background: #fafbfd;
        }

        .form-card-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px;
            flex-shrink: 0;
        }

        .fci-blue {
            background: #e0f2fe;
            color: #0369a1;
        }

        .fci-green {
            background: #dcfce7;
            color: #15803d;
        }

        .fci-purple {
            background: #ede9fe;
            color: #6d28d9;
        }

        .fci-yellow {
            background: #fef9c3;
            color: #854d0e;
        }

        .form-card-title {
            font-size: 14.5px;
            font-weight: 700;
            color: var(--navy);
            margin: 0;
            line-height: 1.3;
        }

        .form-card-subtitle {
            font-size: 12px;
            color: var(--text-muted);
            margin: 0;
        }

        .form-card-body {
            padding: 24px;
        }

        .form-label-custom {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: var(--navy);
            margin-bottom: 7px;
        }

            .form-label-custom .required {
                color: var(--danger);
                margin-left: 3px;
            }

        .form-label-hint {
            font-size: 11.5px;
            font-weight: 400;
            color: var(--text-muted);
            margin-left: 6px;
        }

        .input-wrapper {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 15px;
            pointer-events: none;
            z-index: 1;
        }

        .form-control-custom {
            width: 100%;
            padding: 11px 14px;
            border: 1px solid var(--border);
            border-radius: 10px;
            background: #fff;
            font-family: 'DM Sans', sans-serif;
            font-size: 13.5px;
            color: var(--text-main);
            outline: none;
            transition: border-color .18s, box-shadow .18s, background .18s;
            appearance: none;
        }

            .form-control-custom.with-icon {
                padding-left: 38px;
            }

            .form-control-custom:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(45,156,219,.14);
                background: #fafdff;
            }

            .form-control-custom.is-invalid,
            .stepper-input.is-invalid {
                border-color: var(--danger);
                box-shadow: 0 0 0 3px rgba(239,68,68,.12);
            }

        textarea.form-control-custom {
            resize: vertical;
            min-height: 110px;
            line-height: 1.6;
        }

        .field-hint {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 6px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .field-hint i {
                font-size: 12px;
                color: var(--accent);
            }

        .validation-msg {
            font-size: 12px;
            color: var(--danger);
            margin-top: 5px;
            display: block;
        }

        .number-stepper {
            display: flex;
            align-items: center;
            gap: 0;
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            transition: border-color .18s, box-shadow .18s;
        }

            .number-stepper:focus-within {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(45,156,219,.14);
            }

        .stepper-btn {
            width: 40px;
            height: 44px;
            border: none;
            background: #f8fafc;
            color: var(--text-muted);
            font-size: 16px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background .15s, color .15s;
            flex-shrink: 0;
            user-select: none;
        }

            .stepper-btn:hover {
                background: var(--surface);
                color: var(--navy);
            }

            .stepper-btn:first-child {
                border-right: 1px solid var(--border);
            }

            .stepper-btn:last-child {
                border-left: 1px solid var(--border);
            }

        .stepper-input {
            flex: 1;
            border: none;
            outline: none;
            text-align: center;
            font-family: 'DM Sans', sans-serif;
            font-size: 15px;
            font-weight: 600;
            color: var(--navy);
            background: transparent;
            padding: 0 8px;
            height: 44px;
            -moz-appearance: textfield;
        }

            .stepper-input::-webkit-inner-spin-button,
            .stepper-input::-webkit-outer-spin-button {
                -webkit-appearance: none;
            }

        .price-wrapper {
            position: relative;
        }

        .price-prefix {
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f8fafc;
            border-right: 1px solid var(--border);
            border-radius: 10px 0 0 10px;
            font-weight: 700;
            font-size: 14px;
            color: var(--text-muted);
            pointer-events: none;
            z-index: 1;
        }

        .price-input {
            padding-left: 54px !important;
        }

        .preview-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
            margin-bottom: 18px;
        }

        @@media (max-width: 768px) {
            .preview-grid {
                grid-template-columns: 1fr;
            }
        }

        .preview-card {
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            background: #fff;
        }

        .preview-card-header {
            padding: 12px 14px;
            border-bottom: 1px solid var(--border);
            background: #fafbfd;
            font-size: 12.5px;
            font-weight: 700;
            color: var(--navy);
        }

        .image-preview-box {
            width: 100%;
            height: 200px;
            border: 2px dashed var(--border);
            border-radius: 0 0 12px 12px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            background: #fafbfd;
            font-size: 13px;
            gap: 6px;
            transition: border-color .2s, background .2s;
            overflow: hidden;
            position: relative;
        }

            .image-preview-box.has-image {
                border-style: solid;
                border-color: var(--accent);
                background: #000;
            }

            .image-preview-box img {
                position: absolute;
                inset: 0;
                width: 100%;
                height: 100%;
                object-fit: cover;
                opacity: 0;
                transition: opacity .3s;
            }

                .image-preview-box img.loaded {
                    opacity: 1;
                }

        .preview-placeholder {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            transition: opacity .2s;
            text-align: center;
            padding: 14px;
        }

            .preview-placeholder i {
                font-size: 32px;
                color: #cbd5e1;
            }

        .image-preview-box.has-image .preview-placeholder {
            opacity: 0;
        }

        .badge-selector {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
        }

        .badge-option {
            position: relative;
        }

            .badge-option input[type="radio"] {
                position: absolute;
                opacity: 0;
                width: 0;
                height: 0;
            }

            .badge-option label {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 11px 14px;
                border: 2px solid var(--border);
                border-radius: 10px;
                cursor: pointer;
                transition: border-color .18s, background .18s, box-shadow .18s;
                font-size: 13px;
                font-weight: 600;
                color: var(--text-main);
                user-select: none;
            }

                .badge-option label:hover {
                    border-color: #c4cdd9;
                    background: var(--surface);
                }

            .badge-option input:checked + label {
                border-color: var(--accent);
                background: #f0f9ff;
                box-shadow: 0 0 0 2px rgba(45,156,219,.15);
            }

        .badge-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .bd-popular {
            background: #f59e0b;
        }

        .bd-new {
            background: #10b981;
        }

        .bd-limited {
            background: #ef4444;
        }

        .bd-none {
            background: #94a3b8;
        }

        .status-toggle-wrap {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 18px;
            border: 1px solid var(--border);
            border-radius: 12px;
            background: #fff;
            transition: border-color .18s, background .18s;
            cursor: pointer;
        }

            .status-toggle-wrap:has(input:checked) {
                border-color: var(--success);
                background: #f0fdf4;
            }

        .status-toggle-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .status-icon {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px;
            color: var(--text-muted);
            transition: background .2s, color .2s;
        }

        .status-toggle-wrap:has(input:checked) .status-icon {
            background: #dcfce7;
            color: #15803d;
        }

        .status-label-title {
            font-size: 13.5px;
            font-weight: 600;
            color: var(--navy);
        }

        .status-label-sub {
            font-size: 12px;
            color: var(--text-muted);
        }

        .toggle-switch {
            position: relative;
            width: 48px;
            height: 26px;
            flex-shrink: 0;
        }

            .toggle-switch input {
                display: none;
            }

        .toggle-track {
            position: absolute;
            inset: 0;
            background: #cbd5e1;
            border-radius: 13px;
            cursor: pointer;
            transition: background .25s;
        }

            .toggle-track::after {
                content: '';
                position: absolute;
                left: 3px;
                top: 3px;
                width: 20px;
                height: 20px;
                border-radius: 50%;
                background: #fff;
                box-shadow: 0 1px 4px rgba(0,0,0,.18);
                transition: transform .25s cubic-bezier(.4,0,.2,1);
            }

        .toggle-switch input:checked + .toggle-track {
            background: var(--success);
        }

            .toggle-switch input:checked + .toggle-track::after {
                transform: translateX(22px);
            }

        .submit-card {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 16px;
            box-shadow: var(--shadow-md);
            padding: 22px 24px;
        }

        .btn-submit {
            width: 100%;
            padding: 14px;
            background: var(--accent);
            color: #fff;
            border: none;
            border-radius: 11px;
            font-family: 'DM Sans', sans-serif;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            transition: background .2s, box-shadow .2s, transform .15s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 9px;
            box-shadow: 0 2px 12px rgba(45,156,219,.35);
            margin-bottom: 10px;
        }

            .btn-submit:hover {
                background: var(--accent-dk);
                box-shadow: 0 4px 20px rgba(45,156,219,.45);
                transform: translateY(-1px);
            }

        .btn-cancel-submit {
            width: 100%;
            padding: 12px;
            background: none;
            color: var(--text-muted);
            border: 1px solid var(--border);
            border-radius: 11px;
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: background .15s, color .15s;
            text-align: center;
            display: block;
            text-decoration: none;
        }

            .btn-cancel-submit:hover {
                background: var(--surface);
                color: var(--navy);
            }

        .tips-card {
            background: linear-gradient(135deg, #0d1b2a 0%, #1a3358 100%);
            border-radius: 16px;
            padding: 22px 22px;
            color: #fff;
            margin-bottom: 20px;
        }

        .tips-title {
            font-family: 'Playfair Display', serif;
            font-size: 15px;
            color: #fff;
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .tips-title i {
                color: var(--accent);
                font-size: 16px;
            }

        .tip-item {
            display: flex;
            align-items: flex-start;
            gap: 9px;
            margin-bottom: 10px;
            font-size: 12.5px;
            color: rgba(255,255,255,.75);
            line-height: 1.5;
        }

            .tip-item:last-child {
                margin-bottom: 0;
            }

            .tip-item i {
                font-size: 13px;
                color: var(--accent);
                flex-shrink: 0;
                margin-top: 1px;
            }

        .form-progress {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 18px 20px;
            margin-bottom: 20px;
            box-shadow: var(--shadow-sm);
        }

        .progress-title {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 10px;
            display: flex;
            justify-content: space-between;
        }

        .progress-bar-wrap {
            height: 6px;
            background: var(--surface);
            border-radius: 10px;
            overflow: hidden;
        }

        #formProgressBar {
            height: 100%;
            background: linear-gradient(90deg, var(--accent), #38bdf8);
            border-radius: 10px;
            width: 0%;
            transition: width .4s cubic-bezier(.4,0,.2,1);
        }

        @@media (max-width: 576px) {
            .badge-selector {
                grid-template-columns: 1fr 1fr;
            }

            .form-card-body {
                padding: 16px;
            }
        }
    </style>
}

<div class="section-header">
    <div>
        <p class="page-eyebrow">Tour Management</p>
        <h1 class="page-title">Update Tour</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/AdminTour/TourList" class="text-muted">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/AdminTour/TourList" class="text-muted">Tours</a></li>
                <li class="breadcrumb-item active text-muted">Update Tour</li>
            </ol>
        </nav>
    </div>
    <a href="/AdminTour/TourList" class="btn-back">
        <i class="bi bi-arrow-left"></i>
        Back to List
    </a>
</div>
<div asp-validation-summary="All" class="text-danger mb-3"></div>
<form asp-action="UpdateTour" asp-controller="AdminTour" method="post" id="updateTourForm" enctype="multipart/form-data" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="TourId" />
    <input type="hidden" asp-for="CategoryId" />
    <input type="hidden" asp-for="MapLocationImageUrl" />

    <div class="form-grid">
        <div>
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon fci-blue">
                        <i class="bi bi-info-circle-fill"></i>
                    </div>
                    <div>
                        <p class="form-card-title">Basic Information</p>
                        <p class="form-card-subtitle">Update the main details of the tour</p>
                    </div>
                </div>
                <div class="form-card-body">

                    <div class="mb-4">
                        <label class="form-label-custom" asp-for="TourTitle">
                            Tour Title <span class="required">*</span>
                        </label>
                        <div class="input-wrapper">
                            <i class="bi bi-type input-icon"></i>
                            <input asp-for="TourTitle" class="form-control-custom with-icon" />
                        </div>
                        <span asp-validation-for="TourTitle" class="validation-msg"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label-custom" asp-for="TourDescription">
                            Tour Description <span class="required">*</span>
                        </label>
                        <textarea asp-for="TourDescription" class="form-control-custom"></textarea>
                        <span asp-validation-for="TourDescription" class="validation-msg"></span>
                    </div>

                    <div class="mb-0">
                        <label class="form-label-custom" asp-for="Location">
                            Location <span class="required">*</span>
                        </label>
                        <div class="input-wrapper">
                            <i class="bi bi-geo-alt input-icon"></i>
                            <input asp-for="Location" class="form-control-custom with-icon" />
                        </div>
                        <span asp-validation-for="Location" class="validation-msg"></span>
                    </div>

                </div>
            </div>

            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon fci-purple">
                        <i class="bi bi-sliders2-vertical"></i>
                    </div>
                    <div>
                        <p class="form-card-title">Tour Details</p>
                        <p class="form-card-subtitle">Duration, capacity and price</p>
                    </div>
                </div>
                <div class="form-card-body">

                    <div class="row g-4">
                        <div class="col-sm-6">
                            <label class="form-label-custom" asp-for="DayCount">
                                Duration <span class="required">*</span>
                            </label>
                            <div class="number-stepper">
                                <button type="button" class="stepper-btn" onclick="stepValue('DayCount', -1, 1, 365)">
                                    <i class="bi bi-dash"></i>
                                </button>
                                <input asp-for="DayCount" id="DayCount" class="stepper-input" type="number" min="1" max="365" />
                                <button type="button" class="stepper-btn" onclick="stepValue('DayCount', 1, 1, 365)">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </div>
                            <span asp-validation-for="DayCount" class="validation-msg"></span>
                        </div>

                        <div class="col-sm-6">
                            <label class="form-label-custom" asp-for="Capacity">
                                Capacity <span class="required">*</span>
                            </label>
                            <div class="number-stepper">
                                <button type="button" class="stepper-btn" onclick="stepValue('Capacity', -1, 1, 999)">
                                    <i class="bi bi-dash"></i>
                                </button>
                                <input asp-for="Capacity" id="Capacity" class="stepper-input" type="number" min="1" max="999" />
                                <button type="button" class="stepper-btn" onclick="stepValue('Capacity', 1, 1, 999)">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Capacity" class="validation-msg"></span>
                        </div>

                        <div class="col-12">
                            <label class="form-label-custom" asp-for="Price">
                                Price (USD) <span class="required">*</span>
                            </label>
                            <div class="price-wrapper">
                                <span class="price-prefix">$</span>
                                <input asp-for="Price" id="Price" class="form-control-custom price-input" type="number" min="0" step="0.01" />
                            </div>
                            <span asp-validation-for="Price" class="validation-msg"></span>
                        </div>
                    </div>

                </div>
            </div>

            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon fci-yellow">
                        <i class="bi bi-image-fill"></i>
                    </div>
                    <div>
                        <p class="form-card-title">Visual Assets</p>
                        <p class="form-card-subtitle">Cover image and AI map upload</p>
                    </div>
                </div>
                <div class="form-card-body">

                    <div class="preview-grid">
                        <div class="preview-card">
                            <div class="preview-card-header">Cover Preview</div>
                            <div class="image-preview-box @(string.IsNullOrWhiteSpace(Model.CoverImageUrl) ? "" : "has-image")" id="coverPreviewBox">
                                <img id="coverPreviewImage"
                                     src="@Model.CoverImageUrl"
                                     alt="Cover Preview"
                                     class="@(string.IsNullOrWhiteSpace(Model.CoverImageUrl) ? "" : "loaded")" />
                                <div class="preview-placeholder">
                                    <i class="bi bi-image"></i>
                                    <span>Cover image preview will appear here</span>
                                </div>
                            </div>
                        </div>

                        <div class="preview-card">
                            <div class="preview-card-header">AI Map Preview</div>
                            <div class="image-preview-box @(string.IsNullOrWhiteSpace(Model.MapLocationImageUrl) ? "" : "has-image")" id="mapPreviewBox">
                                <img id="mapPreviewImage"
                                     src="@Model.MapLocationImageUrl"
                                     alt="Map Preview"
                                     class="@(string.IsNullOrWhiteSpace(Model.MapLocationImageUrl) ? "" : "loaded")" />
                                <div class="preview-placeholder">
                                    <i class="bi bi-map"></i>
                                    <span>Current or newly selected map image will appear here</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label-custom" asp-for="CoverImageUrl">
                            Cover Image URL <span class="required">*</span>
                        </label>
                        <div class="input-wrapper">
                            <i class="bi bi-link-45deg input-icon"></i>
                            <input asp-for="CoverImageUrl" id="CoverImageUrl" class="form-control-custom with-icon" />
                        </div>
                        <span asp-validation-for="CoverImageUrl" class="validation-msg"></span>
                    </div>

                    <div class="mb-0">
                        <label class="form-label-custom" asp-for="MapImageFile">
                            New AI Map Image File
                            <span class="form-label-hint">Optional</span>
                        </label>
                        <input asp-for="MapImageFile"
                               id="MapImageFile"
                               type="file"
                               accept=".jpg,.jpeg,.png,.webp"
                               class="form-control-custom" />
                        <p class="field-hint">
                            <i class="bi bi-info-circle"></i>
                            Select a new map image only if you want to replace the current one
                        </p>
                        <span asp-validation-for="MapImageFile" class="validation-msg"></span>
                    </div>

                </div>
            </div>
        </div>

        <div>
            <div class="form-progress">
                <div class="progress-title">
                    <span>Form Completion</span>
                    <span id="progressPercent">0%</span>
                </div>
                <div class="progress-bar-wrap">
                    <div id="formProgressBar"></div>
                </div>
            </div>

            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon fci-green">
                        <i class="bi bi-award-fill"></i>
                    </div>
                    <div>
                        <p class="form-card-title">Tour Badge</p>
                        <p class="form-card-subtitle">Update highlight label</p>
                    </div>
                </div>
                <div class="form-card-body">
                    <div class="badge-selector">
                        <div class="badge-option">
                            <input type="radio" asp-for="Badge" value="" id="badge-none" />
                            <label for="badge-none">
                                <span class="badge-dot bd-none"></span>
                                None
                            </label>
                        </div>

                        <div class="badge-option">
                            <input type="radio" asp-for="Badge" value="Popular" id="badge-popular" />
                            <label for="badge-popular">
                                <span class="badge-dot bd-popular"></span>
                                Popular
                            </label>
                        </div>

                        <div class="badge-option">
                            <input type="radio" asp-for="Badge" value="New" id="badge-new" />
                            <label for="badge-new">
                                <span class="badge-dot bd-new"></span>
                                New
                            </label>
                        </div>

                        <div class="badge-option">
                            <input type="radio" asp-for="Badge" value="Limited" id="badge-limited" />
                            <label for="badge-limited">
                                <span class="badge-dot bd-limited"></span>
                                Limited
                            </label>
                        </div>
                    </div>
                    <span asp-validation-for="Badge" class="validation-msg" style="margin-top:8px;"></span>
                </div>
            </div>

            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon fci-green">
                        <i class="bi bi-toggle2-on"></i>
                    </div>
                    <div>
                        <p class="form-card-title">Publish Status</p>
                        <p class="form-card-subtitle">Tour active / inactive</p>
                    </div>
                </div>
                <div class="form-card-body">
                    <label class="status-toggle-wrap" for="IsStatus">
                        <div class="status-toggle-info">
                            <div class="status-icon" id="statusIcon">
                                <i class="bi @(Model.IsStatus ? "bi-eye-fill" : "bi-eye-slash-fill")" id="statusIconInner"></i>
                            </div>
                            <div>
                                <div class="status-label-title" id="statusLabelTitle">
                                    @(Model.IsStatus ? "Active" : "Inactive")
                                </div>
                                <div class="status-label-sub" id="statusLabelSub">
                                    @(Model.IsStatus ? "The tour will be visible in the list" : "The tour will not be visible in the list")
                                </div>
                            </div>
                        </div>
                        <div class="toggle-switch">
                            <input asp-for="IsStatus" id="IsStatus" type="checkbox" onchange="updateStatusLabel(this)" />
                            <div class="toggle-track"></div>
                        </div>
                    </label>
                    <span asp-validation-for="IsStatus" class="validation-msg" style="margin-top:8px;"></span>
                </div>
            </div>

            <div class="submit-card">
                <button type="submit" class="btn-submit" id="submitBtn">
                    <i class="bi bi-check-circle-fill"></i>
                    Update Tour
                </button>
                <a href="/admin/tours" class="btn-cancel-submit">
                    <i class="bi bi-x-circle me-1"></i> Cancel
                </a>
            </div>

            <div class="tips-card">
                <div class="tips-title">
                    <i class="bi bi-lightbulb-fill"></i>
                    Update Tips
                </div>
                <div class="tip-item">
                    <i class="bi bi-check2-circle"></i>
                    <span>Review all core details before saving changes.</span>
                </div>
                <div class="tip-item">
                    <i class="bi bi-check2-circle"></i>
                    <span>Replace the AI map only when you need a different illustrated route.</span>
                </div>
                <div class="tip-item">
                    <i class="bi bi-check2-circle"></i>
                    <span>Use active status only for tours ready to be listed.</span>
                </div>
                <div class="tip-item">
                    <i class="bi bi-check2-circle"></i>
                    <span>Keep cover URLs valid and high quality.</span>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function stepValue(id, delta, min, max) {
            const input = document.getElementById(id);
            let val = parseInt(input.value) || 0;
            val = Math.min(max, Math.max(min, val + delta));
            input.value = val;
            updateProgress();
        }

        function setupUrlImagePreview(inputId, previewBoxId, previewImageId) {
            const input = document.getElementById(inputId);
            const previewBox = document.getElementById(previewBoxId);
            const previewImg = document.getElementById(previewImageId);

            if (!input || !previewBox || !previewImg) return;

            function clearPreview() {
                previewBox.classList.remove('has-image');
                previewImg.classList.remove('loaded');
                previewImg.removeAttribute('src');
            }

            function loadPreview(url) {
                if (!url) {
                    clearPreview();
                    return;
                }

                previewImg.onload = function () {
                    previewBox.classList.add('has-image');
                    previewImg.classList.add('loaded');
                };

                previewImg.onerror = function () {
                    clearPreview();
                };

                previewImg.src = url;
            }

            input.addEventListener('input', function () {
                loadPreview(this.value.trim());
            });

            loadPreview(input.value.trim());
        }

        function setupFileImagePreview(fileInputId, previewBoxId, previewImageId) {
            const fileInput = document.getElementById(fileInputId);
            const previewBox = document.getElementById(previewBoxId);
            const previewImg = document.getElementById(previewImageId);

            if (!fileInput || !previewBox || !previewImg) return;

            fileInput.addEventListener('change', function () {
                const file = this.files && this.files[0];

                if (!file) return;

                const reader = new FileReader();

                reader.onload = function (e) {
                    previewImg.src = e.target.result;
                    previewImg.classList.add('loaded');
                    previewBox.classList.add('has-image');
                };

                reader.readAsDataURL(file);
            });
        }

        function updateStatusLabel(cb) {
            const title = document.getElementById('statusLabelTitle');
            const sub = document.getElementById('statusLabelSub');
            const icon = document.getElementById('statusIconInner');

            if (cb.checked) {
                title.textContent = 'Active';
                sub.textContent = 'The tour will be visible in the list';
                icon.className = 'bi bi-eye-fill';
            } else {
                title.textContent = 'Inactive';
                sub.textContent = 'The tour will not be visible in the list';
                icon.className = 'bi bi-eye-slash-fill';
            }
        }

        const progressBar = document.getElementById('formProgressBar');
        const progressPct = document.getElementById('progressPercent');

        const requiredTrackedFields = [
            'TourTitle',
            'TourDescription',
            'Location',
            'CoverImageUrl',
            'Price'
        ];

        function updateProgress() {
            let filled = 0;
            const total = requiredTrackedFields.length + 2;

            requiredTrackedFields.forEach(id => {
                const el = document.getElementById(id);
                if (el && el.value.trim().length > 0) filled++;
            });

            const dayCount = parseInt(document.getElementById('DayCount').value) || 0;
            const capacity = parseInt(document.getElementById('Capacity').value) || 0;

            if (dayCount >= 1) filled++;
            if (capacity >= 1) filled++;

            const pct = Math.round((filled / total) * 100);
            progressBar.style.width = pct + '%';
            progressPct.textContent = pct + '%';
        }

        requiredTrackedFields.forEach(id => {
            const el = document.getElementById(id);
            if (el) el.addEventListener('input', updateProgress);
        });

        document.getElementById('DayCount').addEventListener('input', updateProgress);
        document.getElementById('Capacity').addEventListener('input', updateProgress);

        setupUrlImagePreview('CoverImageUrl', 'coverPreviewBox', 'coverPreviewImage');
        setupFileImagePreview('MapImageFile', 'mapPreviewBox', 'mapPreviewImage');

        updateProgress();
        updateStatusLabel(document.getElementById('IsStatus'));
    </script>
}