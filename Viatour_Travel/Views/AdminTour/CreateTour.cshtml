@model CreateTourDto

@{
    ViewData["Title"] = "Create Tour";
    Layout = "~/Views/Shared/_AdminTourLayout.cshtml";
}

@section Styles {
    <style>
        .section-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 28px;
        }

        .page-eyebrow {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--accent);
            margin-bottom: 4px;
        }

        .page-title {
            margin: 0;
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #fff;
            color: var(--text-muted);
            border: 1px solid var(--border);
            padding: 10px 18px;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 13.5px;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 340px;
            gap: 24px;
            align-items: start;
        }

        @@media (max-width: 1100px) {
            .form-grid {
                grid-template-columns: 1fr;
            }
        }

        .form-card, .submit-card, .form-progress {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 16px;
            box-shadow: var(--shadow-md);
            overflow: hidden;
            margin-bottom: 20px;
        }

        .form-card-header {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 18px 24px;
            border-bottom: 1px solid var(--border);
            background: #fafbfd;
        }

        .form-card-body {
            padding: 24px;
        }

        .form-card-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px;
            flex-shrink: 0;
        }

        .fci-blue {
            background: #e0f2fe;
            color: #0369a1;
        }

        .fci-purple {
            background: #ede9fe;
            color: #6d28d9;
        }

        .fci-yellow {
            background: #fef9c3;
            color: #854d0e;
        }

        .fci-green {
            background: #dcfce7;
            color: #15803d;
        }

        .form-card-title {
            font-size: 14.5px;
            font-weight: 700;
            color: var(--navy);
            margin: 0;
        }

        .form-card-subtitle {
            font-size: 12px;
            color: var(--text-muted);
            margin: 0;
        }

        .form-label-custom {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: var(--navy);
            margin-bottom: 7px;
        }

        .required {
            color: var(--danger);
        }

        .input-wrapper {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 15px;
            pointer-events: none;
            z-index: 1;
        }

        .form-control-custom {
            width: 100%;
            padding: 11px 14px;
            border: 1px solid var(--border);
            border-radius: 10px;
            background: #fff;
            font-family: 'DM Sans', sans-serif;
            font-size: 13.5px;
            color: var(--text-main);
            outline: none;
            transition: .18s;
            appearance: none;
        }

            .form-control-custom.with-icon {
                padding-left: 38px;
            }

            .form-control-custom:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(45,156,219,.14);
                background: #fafdff;
            }

        textarea.form-control-custom {
            resize: vertical;
            min-height: 110px;
            line-height: 1.6;
        }

        .validation-msg {
            font-size: 12px;
            color: var(--danger);
            margin-top: 5px;
            display: block;
        }

        .field-hint {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 6px;
        }

        .preview-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
            margin-bottom: 18px;
        }

        @@media (max-width: 768px) {
            .preview-grid {
                grid-template-columns: 1fr;
            }
        }

        .preview-card {
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            background: #fff;
        }

        .preview-card-header {
            padding: 12px 14px;
            border-bottom: 1px solid var(--border);
            background: #fafbfd;
            font-size: 12.5px;
            font-weight: 700;
            color: var(--navy);
        }

        .image-preview-box {
            width: 100%;
            height: 200px;
            border: 2px dashed var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            background: #fafbfd;
        }

            .image-preview-box img {
                position: absolute;
                inset: 0;
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: none;
            }

            .image-preview-box.has-image img {
                display: block;
            }

        .preview-placeholder {
            text-align: center;
            color: var(--text-muted);
            padding: 14px;
        }

        .number-stepper {
            display: flex;
            align-items: center;
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
        }

        .stepper-btn {
            width: 40px;
            height: 44px;
            border: none;
            background: #f8fafc;
            cursor: pointer;
        }

        .stepper-input {
            flex: 1;
            border: none;
            outline: none;
            text-align: center;
            height: 44px;
            font-weight: 600;
        }

        .price-wrapper {
            position: relative;
        }

        .price-prefix {
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f8fafc;
            border-right: 1px solid var(--border);
            border-radius: 10px 0 0 10px;
            font-weight: 700;
        }

        .price-input {
            padding-left: 54px !important;
        }

        .btn-submit {
            width: 100%;
            padding: 14px;
            background: var(--accent);
            color: #fff;
            border: none;
            border-radius: 11px;
            font-weight: 700;
            cursor: pointer;
        }

        .btn-cancel-submit {
            width: 100%;
            padding: 12px;
            background: none;
            color: var(--text-muted);
            border: 1px solid var(--border);
            border-radius: 11px;
            text-align: center;
            display: block;
            text-decoration: none;
            margin-top: 10px;
        }

        .badge-selector {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
        }

        .badge-option input[type="radio"] {
            display: none;
        }

        .badge-option label {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 11px 14px;
            border: 2px solid var(--border);
            border-radius: 10px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
        }

        .badge-option input:checked + label {
            border-color: var(--accent);
            background: #f0f9ff;
        }

        .badge-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
        }

        .bd-popular {
            background: #f59e0b;
        }

        .bd-new {
            background: #10b981;
        }

        .bd-limited {
            background: #ef4444;
        }

        .bd-none {
            background: #94a3b8;
        }

        .status-toggle-wrap {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 18px;
            border: 1px solid var(--border);
            border-radius: 12px;
            background: #fff;
        }

        .toggle-switch input {
            display: none;
        }

        .toggle-track {
            width: 48px;
            height: 26px;
            background: #cbd5e1;
            border-radius: 13px;
            position: relative;
            display: block;
        }

            .toggle-track::after {
                content: '';
                position: absolute;
                left: 3px;
                top: 3px;
                width: 20px;
                height: 20px;
                background: #fff;
                border-radius: 50%;
                transition: .25s;
            }

        .toggle-switch input:checked + .toggle-track {
            background: var(--success);
        }

            .toggle-switch input:checked + .toggle-track::after {
                transform: translateX(22px);
            }

        .form-progress {
            padding: 18px 20px;
        }

        .progress-title {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 10px;
            display: flex;
            justify-content: space-between;
        }

        .progress-bar-wrap {
            height: 6px;
            background: var(--surface);
            border-radius: 10px;
            overflow: hidden;
        }

        #formProgressBar {
            height: 100%;
            background: linear-gradient(90deg, var(--accent), #38bdf8);
            width: 0%;
            transition: .4s;
        }
    </style>
}

<div class="section-header">
    <div>
        <p class="page-eyebrow">Tour Management</p>
        <h1 class="page-title">Add New Tour</h1>
    </div>
    <a href="/admin/tours" class="btn-back">
        <i class="bi bi-arrow-left"></i>
        Back to List
    </a>
</div>

<form method="post" id="createTourForm" enctype="multipart/form-data" novalidate>
    @Html.AntiForgeryToken()

    <div class="form-grid">
        <div>
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon fci-blue"><i class="bi bi-info-circle-fill"></i></div>
                    <div>
                        <p class="form-card-title">Basic Information</p>
                        <p class="form-card-subtitle">Tour name and description</p>
                    </div>
                </div>
                <div class="form-card-body">
                    <div class="mb-4">
                        <label class="form-label-custom" asp-for="TourTitle">Tour Title <span class="required">*</span></label>
                        <div class="input-wrapper">
                            <i class="bi bi-type input-icon"></i>
                            <input asp-for="TourTitle" class="form-control-custom with-icon" />
                        </div>
                        <span asp-validation-for="TourTitle" class="validation-msg"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label-custom" asp-for="TourDescription">Tour Description <span class="required">*</span></label>
                        <textarea asp-for="TourDescription" class="form-control-custom"></textarea>
                        <span asp-validation-for="TourDescription" class="validation-msg"></span>
                    </div>

                    <div class="mb-0">
                        <label class="form-label-custom" asp-for="Location">Location <span class="required">*</span></label>
                        <div class="input-wrapper">
                            <i class="bi bi-geo-alt input-icon"></i>
                            <input asp-for="Location" class="form-control-custom with-icon" />
                        </div>
                        <span asp-validation-for="Location" class="validation-msg"></span>
                    </div>
                </div>
            </div>

            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon fci-purple"><i class="bi bi-sliders2-vertical"></i></div>
                    <div>
                        <p class="form-card-title">Tour Details</p>
                        <p class="form-card-subtitle">Duration, capacity and pricing</p>
                    </div>
                </div>
                <div class="form-card-body">
                    <div class="row g-4">
                        <div class="col-sm-6">
                            <label class="form-label-custom" asp-for="DayCount">Duration <span class="required">*</span></label>
                            <div class="number-stepper">
                                <button type="button" class="stepper-btn" onclick="stepValue('DayCount', -1, 1, 365)">-</button>
                                <input asp-for="DayCount" id="DayCount" class="stepper-input" type="number" min="1" max="365" value="1" />
                                <button type="button" class="stepper-btn" onclick="stepValue('DayCount', 1, 1, 365)">+</button>
                            </div>
                            <span asp-validation-for="DayCount" class="validation-msg"></span>
                        </div>

                        <div class="col-sm-6">
                            <label class="form-label-custom" asp-for="Capacity">Capacity <span class="required">*</span></label>
                            <div class="number-stepper">
                                <button type="button" class="stepper-btn" onclick="stepValue('Capacity', -1, 1, 999)">-</button>
                                <input asp-for="Capacity" id="Capacity" class="stepper-input" type="number" min="1" max="999" value="10" />
                                <button type="button" class="stepper-btn" onclick="stepValue('Capacity', 1, 1, 999)">+</button>
                            </div>
                            <span asp-validation-for="Capacity" class="validation-msg"></span>
                        </div>

                        <div class="col-12">
                            <label class="form-label-custom" asp-for="Price">Price (USD) <span class="required">*</span></label>
                            <div class="price-wrapper">
                                <span class="price-prefix">$</span>
                                <input asp-for="Price" id="Price" class="form-control-custom price-input" type="number" min="0" step="0.01" />
                            </div>
                            <span asp-validation-for="Price" class="validation-msg"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon fci-yellow"><i class="bi bi-image-fill"></i></div>
                    <div>
                        <p class="form-card-title">Visual Assets</p>
                        <p class="form-card-subtitle">Cover and AI map images</p>
                    </div>
                </div>
                <div class="form-card-body">
                    <div class="preview-grid">
                        <div class="preview-card">
                            <div class="preview-card-header">Cover Preview</div>
                            <div class="image-preview-box" id="coverPreviewBox">
                                <img id="coverPreviewImage" alt="Cover Preview" />
                                <div class="preview-placeholder">Cover image preview will appear here</div>
                            </div>
                        </div>

                        <div class="preview-card">
                            <div class="preview-card-header">AI Map Preview</div>
                            <div class="image-preview-box" id="mapPreviewBox">
                                <img id="mapPreviewImage" alt="Map Preview" />
                                <div class="preview-placeholder">AI map preview will appear here</div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label-custom" asp-for="CoverImageUrl">Cover Image URL <span class="required">*</span></label>
                        <div class="input-wrapper">
                            <i class="bi bi-link-45deg input-icon"></i>
                            <input asp-for="CoverImageUrl" id="CoverImageUrl" class="form-control-custom with-icon" />
                        </div>
                        <span asp-validation-for="CoverImageUrl" class="validation-msg"></span>
                    </div>

                    <div class="mb-0">
                        <label class="form-label-custom" asp-for="MapImageFile">AI Map Image File</label>
                        <input asp-for="MapImageFile" id="MapImageFile" type="file" accept=".jpg,.jpeg,.png,.webp" class="form-control-custom" />
                        <span asp-validation-for="MapImageFile" class="validation-msg"></span>
                    </div>
                </div>
            </div>
        </div>

        <div>
            <div class="form-progress">
                <div class="progress-title">
                    <span>Form Completion</span>
                    <span id="progressPercent">0%</span>
                </div>
                <div class="progress-bar-wrap">
                    <div id="formProgressBar"></div>
                </div>
            </div>

            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon fci-green"><i class="bi bi-award-fill"></i></div>
                    <div>
                        <p class="form-card-title">Tour Badge</p>
                        <p class="form-card-subtitle">Highlight label</p>
                    </div>
                </div>
                <div class="form-card-body">
                    <div class="badge-selector">
                        <div class="badge-option">
                            <input type="radio" asp-for="Badge" value="" id="badge-none" checked />
                            <label for="badge-none"><span class="badge-dot bd-none"></span>None</label>
                        </div>
                        <div class="badge-option">
                            <input type="radio" asp-for="Badge" value="Popular" id="badge-popular" />
                            <label for="badge-popular"><span class="badge-dot bd-popular"></span>Popular</label>
                        </div>
                        <div class="badge-option">
                            <input type="radio" asp-for="Badge" value="New" id="badge-new" />
                            <label for="badge-new"><span class="badge-dot bd-new"></span>New</label>
                        </div>
                        <div class="badge-option">
                            <input type="radio" asp-for="Badge" value="Limited" id="badge-limited" />
                            <label for="badge-limited"><span class="badge-dot bd-limited"></span>Limited</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon fci-green"><i class="bi bi-toggle2-on"></i></div>
                    <div>
                        <p class="form-card-title">Publish Status</p>
                        <p class="form-card-subtitle">Tour active / inactive</p>
                    </div>
                </div>
                <div class="form-card-body">
                    <label class="status-toggle-wrap" for="IsStatus">
                        <span>Active</span>
                        <div class="toggle-switch">
                            <input asp-for="IsStatus" id="IsStatus" type="checkbox" />
                            <label class="toggle-track" for="IsStatus"></label>
                        </div>
                    </label>
                </div>
            </div>

            <div class="submit-card" style="padding:22px 24px;">
                <button type="submit" class="btn-submit" id="submitBtn">Save Tour</button>
                <a href="/admin/tours" class="btn-cancel-submit">Cancel</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function stepValue(id, delta, min, max) {
            const input = document.getElementById(id);
            let val = parseInt(input.value) || 0;
            val = Math.min(max, Math.max(min, val + delta));
            input.value = val;
            updateProgress();
        }

        function setupUrlImagePreview(inputId, previewBoxId, previewImageId) {
            const input = document.getElementById(inputId);
            const previewBox = document.getElementById(previewBoxId);
            const previewImg = document.getElementById(previewImageId);
            if (!input || !previewBox || !previewImg) return;

            input.addEventListener('input', function () {
                const url = this.value.trim();
                if (!url) {
                    previewBox.classList.remove('has-image');
                    previewImg.removeAttribute('src');
                    return;
                }

                previewImg.onload = function () {
                    previewBox.classList.add('has-image');
                };

                previewImg.onerror = function () {
                    previewBox.classList.remove('has-image');
                };

                previewImg.src = url;
            });
        }

        function setupFileImagePreview(fileInputId, previewBoxId, previewImageId) {
            const fileInput = document.getElementById(fileInputId);
            const previewBox = document.getElementById(previewBoxId);
            const previewImg = document.getElementById(previewImageId);
            if (!fileInput || !previewBox || !previewImg) return;

            fileInput.addEventListener('change', function () {
                const file = this.files[0];
                if (!file) {
                    previewBox.classList.remove('has-image');
                    previewImg.removeAttribute('src');
                    return;
                }

                const reader = new FileReader();
                reader.onload = function (e) {
                    previewImg.src = e.target.result;
                    previewBox.classList.add('has-image');
                };
                reader.readAsDataURL(file);
            });
        }

        const progressBar = document.getElementById('formProgressBar');
        const progressPct = document.getElementById('progressPercent');

        const trackedFields = ['TourTitle', 'TourDescription', 'Location', 'CoverImageUrl', 'Price'];

        function updateProgress() {
            let filled = 0;
            const total = trackedFields.length + 2;

            trackedFields.forEach(id => {
                const el = document.getElementById(id);
                if (el && el.value.trim() !== '') filled++;
            });

            const dayCount = parseInt(document.getElementById('DayCount').value) || 0;
            const capacity = parseInt(document.getElementById('Capacity').value) || 0;

            if (dayCount > 0) filled++;
            if (capacity > 0) filled++;

            const pct = Math.round((filled / total) * 100);
            progressBar.style.width = pct + '%';
            progressPct.textContent = pct + '%';
        }

        trackedFields.forEach(id => {
            const el = document.getElementById(id);
            if (el) el.addEventListener('input', updateProgress);
        });

        document.getElementById('DayCount').addEventListener('input', updateProgress);
        document.getElementById('Capacity').addEventListener('input', updateProgress);

        setupUrlImagePreview('CoverImageUrl', 'coverPreviewBox', 'coverPreviewImage');
        setupFileImagePreview('MapImageFile', 'mapPreviewBox', 'mapPreviewImage');

        updateProgress();
    </script>
}