@model Viatour_Travel.Dtos.ReviewDtos.CreateReviewDto

@{
    ViewData["Title"] = "Write a Review";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
}

<section class="review-create-page">
    <div class="tf-container">
        <div class="review-create-shell">
            <div class="review-create-header">
                <span class="review-create-badge">GUEST FEEDBACK</span>
                <h1 class="review-create-title">Write a Review</h1>
                <p class="review-create-subtitle">
                    Share your experience for this tour. Your review will be submitted for admin approval before it becomes visible.
                </p>
            </div>

            <div class="review-create-card">
                @if (!string.IsNullOrEmpty(Model?.TourId))
                {
                    <div class="tour-review-info">
                        <i class="icon-map-1"></i>
                        <span>Tour ID: <strong>@Model.TourId</strong></span>
                    </div>
                }

                <form asp-action="CreateReview" method="post" novalidate id="reviewForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                    <input type="hidden" asp-for="TourId" value="@Model?.TourId" />

                    <div class="form-grid">
                        <div class="form-group full">
                            <label asp-for="NameSurname" class="form-label-modern">
                                Full Name
                            </label>
                            <input asp-for="NameSurname"
                                   class="form-control-modern"
                                   placeholder="Enter your full name"
                                   maxlength="100" />
                            <span asp-validation-for="NameSurname" class="validation-modern"></span>
                        </div>

                        <div class="form-group full">
                            <label asp-for="Detail" class="form-label-modern">
                                Review Details
                            </label>
                            <textarea asp-for="Detail"
                                      class="form-control-modern form-textarea-modern"
                                      placeholder="Describe your experience with the tour..."></textarea>
                            <span asp-validation-for="Detail" class="validation-modern"></span>
                        </div>

                        <div class="form-group full">
                            <label class="form-label-modern">Your Rating</label>

                            <div class="rating-box-modern">
                                <div class="star-rating-modern" id="starRating">
                                    <input type="radio" asp-for="Score" id="star5" value="5" />
                                    <label for="star5" title="Excellent">&#9733;</label>

                                    <input type="radio" asp-for="Score" id="star4" value="4" />
                                    <label for="star4" title="Very Good">&#9733;</label>

                                    <input type="radio" asp-for="Score" id="star3" value="3" />
                                    <label for="star3" title="Good">&#9733;</label>

                                    <input type="radio" asp-for="Score" id="star2" value="2" />
                                    <label for="star2" title="Average">&#9733;</label>

                                    <input type="radio" asp-for="Score" id="star1" value="1" />
                                    <label for="star1" title="Poor">&#9733;</label>
                                </div>

                                <span id="starScoreText" class="rating-text-modern"></span>
                            </div>

                            <span asp-validation-for="Score" class="validation-modern"></span>
                        </div>
                    </div>

                    <div class="review-form-footer">
                        <a href="/Tour/TourDetail/@Model.TourId" class="btn-back-review">
                            Back to Tour
                        </a>

                        <button type="submit" class="btn-submit-review">
                            Submit Review
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<style>
    .review-create-page {
        padding: 40px 0 90px;
        background: radial-gradient(circle at top left, rgba(16,185,129,.08), transparent 28%), radial-gradient(circle at top right, rgba(37,99,235,.06), transparent 22%);
    }

    .review-create-shell {
        max-width: 860px;
        margin: 0 auto;
    }

    .review-create-header {
        text-align: center;
        margin-bottom: 28px;
    }

    .review-create-badge {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(16,185,129,0.12);
        color: #047857;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: .08em;
        text-transform: uppercase;
        margin-bottom: 14px;
    }

    .review-create-title {
        font-size: 42px;
        line-height: 1.1;
        font-weight: 800;
        margin-bottom: 10px;
        color: #0f172a;
    }

    .review-create-subtitle {
        max-width: 700px;
        margin: 0 auto;
        color: #64748b;
        font-size: 15px;
        line-height: 1.8;
    }

    .review-create-card {
        background: #fff;
        border-radius: 26px;
        padding: 34px;
        box-shadow: 0 18px 45px rgba(15,23,42,0.08);
        border: 1px solid #eef2f7;
    }

    .tour-review-info {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 10px 16px;
        border-radius: 999px;
        background: #ecfdf5;
        color: #047857;
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 24px;
        border: 1px solid #a7f3d0;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    .form-group.full {
        grid-column: 1 / -1;
    }

    .form-label-modern {
        display: block;
        margin-bottom: 8px;
        font-size: 14px;
        font-weight: 700;
        color: #0f172a;
    }

    .form-control-modern {
        width: 100%;
        border: 1.5px solid #dbe3ee;
        border-radius: 14px;
        background: #f8fafc;
        padding: 14px 16px;
        font-size: 14px;
        color: #0f172a;
        transition: all .2s ease;
        outline: none;
    }

        .form-control-modern:focus {
            border-color: #10b981;
            background: #fff;
            box-shadow: 0 0 0 4px rgba(16,185,129,0.10);
        }

        .form-control-modern::placeholder {
            color: #94a3b8;
        }

    .form-textarea-modern {
        min-height: 150px;
        resize: vertical;
    }

    .rating-box-modern {
        border: 1.5px solid #dbe3ee;
        border-radius: 14px;
        background: #f8fafc;
        padding: 16px;
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
    }

    .star-rating-modern {
        display: flex;
        flex-direction: row-reverse;
        gap: 6px;
    }

        .star-rating-modern input[type="radio"] {
            display: none;
        }

        .star-rating-modern label {
            cursor: pointer;
            font-size: 34px;
            line-height: 1;
            color: #d1d5db;
            transition: .18s ease;
        }

            .star-rating-modern label:hover,
            .star-rating-modern label:hover ~ label,
            .star-rating-modern input:checked ~ label {
                color: #f59e0b;
            }

    .rating-text-modern {
        font-size: 14px;
        font-weight: 700;
        color: #b45309;
        min-width: 130px;
    }

    .validation-modern {
        display: block;
        margin-top: 6px;
        color: #dc2626;
        font-size: 12px;
        font-weight: 500;
    }

    .review-form-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        margin-top: 28px;
        flex-wrap: wrap;
    }

    .btn-back-review {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 13px 22px;
        border-radius: 14px;
        border: 1px solid #dbe3ee;
        background: #fff;
        color: #334155;
        font-weight: 700;
        transition: .2s ease;
    }

        .btn-back-review:hover {
            background: #f8fafc;
            color: #0f172a;
        }

    .btn-submit-review {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 14px 24px;
        border-radius: 14px;
        border: none;
        background: linear-gradient(135deg, #10b981, #14b8a6);
        color: #fff;
        font-weight: 800;
        min-width: 180px;
        box-shadow: 0 12px 28px rgba(16,185,129,0.24);
        transition: .2s ease;
    }

        .btn-submit-review:hover {
            transform: translateY(-2px);
            color: #fff;
            box-shadow: 0 16px 34px rgba(16,185,129,0.28);
        }

    @@media (max-width: 767px) {
        .review-create-page {
            padding: 24px 0 70px;
        }

        .review-create-title {
            font-size: 30px;
        }

        .review-create-card {
            padding: 22px;
            border-radius: 20px;
        }

        .form-grid {
            grid-template-columns: 1fr;
        }

        .review-form-footer {
            flex-direction: column;
            align-items: stretch;
        }

        .btn-back-review,
        .btn-submit-review {
            width: 100%;
        }
    }
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

<script>
    const scoreLabels = {
        1: 'Poor',
        2: 'Average',
        3: 'Good',
        4: 'Very Good',
        5: 'Excellent'
    };

    document.querySelectorAll('#starRating input[type="radio"]').forEach(function (radio) {
        radio.addEventListener('change', function () {
            const scoreText = document.getElementById('starScoreText');
            scoreText.textContent = scoreLabels[this.value] || '';
        });
    });
</script>