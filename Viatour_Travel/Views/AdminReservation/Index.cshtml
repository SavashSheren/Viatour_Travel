@model List<Viatour_Travel.Dtos.ReservationDtos.ResultReservationDto>

@{
    ViewData["Title"] = "Reservation Management";
    Layout = "~/Views/Shared/_AdminTourLayout.cshtml";
}

<div class="rev-wrap">
    <div class="rev-header">
        <h2>Reservation Management</h2>
        <p>Approve or delete customer reservations.</p>
    </div>

    <div class="rev-stats">
        <div class="stat-card">
            <p class="stat-label">Total</p>
            <p class="stat-val">@(Model?.Count ?? 0)</p>
        </div>

        <div class="stat-card">
            <p class="stat-label">Pending</p>
            <p class="stat-val warning">@(Model?.Count(x => !x.Status) ?? 0)</p>
        </div>

        <div class="stat-card">
            <p class="stat-label">Approved</p>
            <p class="stat-val success">@(Model?.Count(x => x.Status) ?? 0)</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="rev-list">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                var initials = string.Join("",
                item.NameSurname.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                .Take(2)
                .Select(w => w[0].ToString().ToUpper()));

                <div class="rev-card">
                    <div class="rev-card-top">
                        <div class="rev-meta">
                            <div class="avatar">@initials</div>
                            <div>
                                <p class="rev-name">@item.NameSurname</p>
                                <p class="rev-date">@item.CreatedDate.ToString("dd.MM.yyyy")</p>
                            </div>
                        </div>

                        @if (item.Status)
                        {
                            <span class="badge badge-approved">Approved</span>
                        }
                        else
                        {
                            <span class="badge badge-pending">Pending</span>
                        }
                    </div>

                    <p class="rev-comment"><strong>Tour:</strong> @item.TourTitle</p>
                    <p class="rev-comment"><strong>Reservation No:</strong> @item.ReservationNumber</p>
                    <p class="rev-comment"><strong>Email:</strong> @item.Email</p>
                    <p class="rev-comment"><strong>Phone:</strong> @item.Phone</p>
                    <p class="rev-comment"><strong>Person Count:</strong> @item.PersonCount</p>
                    <p class="rev-comment"><strong>Travel Date:</strong> @item.TravelDate.ToString("dd.MM.yyyy")</p>

                    @if (!string.IsNullOrWhiteSpace(item.Note))
                    {
                        <p class="rev-comment"><strong>Note:</strong> @item.Note</p>
                    }

                    <div class="rev-actions">
                        <a asp-action="ExportExcel"
                           asp-route-tourId="@item.TourId"
                           class="btn-export-report btn-export-excel">
                            Export Excel
                        </a>

                        <a asp-action="ExportPdf"
                           asp-route-tourId="@item.TourId"
                           class="btn-export-report btn-export-pdf">
                            Export PDF
                        </a>

                        @if (!item.Status)
                        {
                            <form method="post"
                                  asp-action="Approve"
                                  asp-route-id="@item.ReservationId"
                                  class="action-form">
                                <button type="submit" class="btn-approve">
                                    ✔ Approve
                                </button>
                            </form>
                        }

                        <form method="post"
                              asp-action="Delete"
                              asp-route-id="@item.ReservationId"
                              class="action-form"
                              onsubmit="return confirm('Are you sure you want to delete this reservation?');">
                            <button type="submit" class="btn-delete">
                                Delete
                            </button>
                        </form>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-info">No reservations found yet.</div>
        }
    </div>
</div>

<style>
    .action-form {
        margin: 0;
    }

    .btn-export-report,
    .btn-approve,
    .btn-delete {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 14px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-export-excel {
        background: #ecfdf5;
        color: #065f46;
    }

        .btn-export-excel:hover {
            background: #d1fae5;
        }

    .btn-export-pdf {
        background: #fef2f2;
        color: #991b1b;
    }

        .btn-export-pdf:hover {
            background: #fee2e2;
        }
    .rev-wrap {
        padding: 1.5rem;
        font-family: inherit;
    }

    .rev-header {
        margin-bottom: 1.5rem;
    }

        .rev-header h2 {
            font-size: 20px;
            font-weight: 500;
            margin: 0 0 4px;
        }

        .rev-header p {
            font-size: 13px;
            color: #6b7280;
            margin: 0;
        }

    .rev-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
        margin-bottom: 1.5rem;
    }

    .stat-card {
        background: #f9fafb;
        border-radius: 10px;
        padding: 14px 16px;
    }

    .stat-label {
        font-size: 12px;
        color: #6b7280;
        margin: 0 0 6px;
    }

    .stat-val {
        font-size: 22px;
        font-weight: 500;
        margin: 0;
        color: #111;
    }

        .stat-val.warning {
            color: #d97706;
        }

        .stat-val.success {
            color: #059669;
        }

    .rev-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .rev-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 16px 18px;
    }

    .rev-card-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 10px;
    }

    .rev-meta {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #dbeafe;
        color: #1d4ed8;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 500;
        flex-shrink: 0;
    }

    .rev-name {
        font-size: 14px;
        font-weight: 500;
        margin: 0 0 3px;
    }

    .rev-date {
        font-size: 12px;
        color: #9ca3af;
        margin: 0;
    }

    .badge {
        font-size: 11px;
        font-weight: 500;
        padding: 3px 10px;
        border-radius: 999px;
    }

    .badge-pending {
        background: #fef3c7;
        color: #92400e;
    }

    .badge-approved {
        background: #d1fae5;
        color: #065f46;
    }

    .rev-comment {
        font-size: 13px;
        color: #4b5563;
        line-height: 1.6;
        margin: 0 0 8px;
    }

    .rev-actions {
        display: flex;
        gap: 8px;
        padding-top: 12px;
        border-top: 1px solid #f3f4f6;
        flex-wrap: wrap;
    }

        .rev-actions form {
            margin: 0;
        }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        font-weight: 500;
        padding: 6px 14px;
        border-radius: 8px;
        border: 1px solid;
        cursor: pointer;
        transition: background 0.15s;
        background: transparent;
    }

    .btn-approve {
        border-color: #6ee7b7;
        color: #065f46;
    }

        .btn-approve:hover {
            background: #d1fae5;
        }

    .btn-delete {
        border-color: #fca5a5;
        color: #991b1b;
    }

        .btn-delete:hover {
            background: #fee2e2;
        }

    @@media (max-width: 768px) {
        .rev-stats {
            grid-template-columns: 1fr;
        }

        .rev-card-top {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>