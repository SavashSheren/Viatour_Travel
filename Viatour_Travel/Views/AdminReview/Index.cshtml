@model List<Viatour_Travel.Dtos.ReviewDtos.ResultReviewDto>

@{
    ViewData["Title"] = "Review Management";
    Layout = "~/Views/Shared/_AdminTourLayout.cshtml";

    var totalCount = Model?.Count ?? 0;
    var pendingCount = Model?.Count(x => !x.Status) ?? 0;
    var approvedCount = Model?.Count(x => x.Status) ?? 0;
}

@section Styles {
    <style>
        .review-root {
            padding: 6px;
        }

        .review-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .review-title {
            font-size: 34px;
            font-weight: 800;
            color: #111827;
            margin: 0 0 8px;
            line-height: 1.1;
        }

        .review-subtitle {
            margin: 0;
            font-size: 14px;
            color: #6b7280;
        }

        .review-live-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #ecfeff;
            color: #0f766e;
            border: 1px solid #a5f3fc;
            border-radius: 999px;
            padding: 10px 14px;
            font-size: 12px;
            font-weight: 800;
            white-space: nowrap;
        }

        .review-stats {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 18px;
            margin-bottom: 24px;
        }

        .review-stat-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 20px;
            padding: 22px;
            box-shadow: 0 10px 28px rgba(15, 23, 42, 0.05);
        }

        .review-stat-label {
            font-size: 14px;
            color: #6b7280;
            font-weight: 600;
            margin-bottom: 12px;
        }

        .review-stat-value {
            font-size: 40px;
            font-weight: 800;
            line-height: 1;
            color: #111827;
        }

            .review-stat-value.pending {
                color: #d97706;
            }

            .review-stat-value.approved {
                color: #059669;
            }

        .review-toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .review-toolbar-left {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .review-toolbar-title {
            font-size: 20px;
            font-weight: 800;
            color: #111827;
        }

        .review-toolbar-note {
            font-size: 13px;
            color: #6b7280;
        }

        .review-filter-group {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .review-filter-btn {
            border: 1px solid #dbe1ea;
            background: #fff;
            color: #374151;
            border-radius: 999px;
            padding: 10px 14px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            transition: .2s ease;
        }

            .review-filter-btn:hover {
                background: #f9fafb;
            }

            .review-filter-btn.active {
                background: #111827;
                color: #fff;
                border-color: #111827;
            }

        .review-alert {
            border-radius: 16px;
            padding: 14px 16px;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 18px;
        }

            .review-alert.success {
                background: #ecfdf5;
                color: #065f46;
                border: 1px solid #a7f3d0;
            }

            .review-alert.error {
                background: #fef2f2;
                color: #991b1b;
                border: 1px solid #fecaca;
            }

        .review-list {
            display: grid;
            gap: 18px;
        }

        .review-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 22px;
            padding: 22px;
            box-shadow: 0 10px 28px rgba(15, 23, 42, 0.05);
            transition: .2s ease;
        }

            .review-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 16px 34px rgba(15, 23, 42, 0.08);
            }

        .review-card-top {
            display: flex;
            justify-content: space-between;
            gap: 18px;
            align-items: flex-start;
            flex-wrap: wrap;
            margin-bottom: 14px;
        }

        .review-user {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .review-avatar {
            width: 52px;
            height: 52px;
            border-radius: 16px;
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            font-weight: 800;
            box-shadow: 0 10px 20px rgba(37, 99, 235, 0.22);
        }

        .review-user-name {
            font-size: 17px;
            font-weight: 800;
            color: #111827;
            margin-bottom: 4px;
        }

        .review-user-meta {
            font-size: 13px;
            color: #6b7280;
        }

        .review-status {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 96px;
            padding: 9px 14px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 800;
        }

            .review-status.pending {
                background: #fff7ed;
                color: #c2410c;
            }

            .review-status.approved {
                background: #ecfdf5;
                color: #047857;
            }

        .review-rating-row {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 14px;
            flex-wrap: wrap;
        }

        .review-stars {
            color: #f59e0b;
            font-size: 18px;
            letter-spacing: 2px;
        }

        .review-score-text {
            font-size: 13px;
            font-weight: 700;
            color: #6b7280;
        }

        .review-text {
            font-size: 15px;
            line-height: 1.8;
            color: #374151;
            background: #f9fafb;
            border: 1px solid #eef2f7;
            border-radius: 18px;
            padding: 16px;
            margin-bottom: 16px;
        }

        .review-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .review-form {
            margin: 0;
        }

        .btn-approve,
        .btn-delete {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 120px;
            border: none;
            border-radius: 12px;
            padding: 11px 16px;
            font-size: 13px;
            font-weight: 800;
            cursor: pointer;
            transition: .2s ease;
        }

        .btn-approve {
            background: #ecfdf5;
            color: #047857;
        }

            .btn-approve:hover {
                background: #d1fae5;
            }

        .btn-delete {
            background: #fef2f2;
            color: #b91c1c;
        }

            .btn-delete:hover {
                background: #fee2e2;
            }

        .review-empty {
            background: #fff;
            border: 1px dashed #d1d5db;
            border-radius: 22px;
            padding: 40px 24px;
            text-align: center;
            color: #6b7280;
            font-size: 15px;
        }

        @@media (max-width: 992px) {
            .review-stats {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="review-root">
    <div class="review-header">
        <div>
            <h1 class="review-title">Review Management</h1>
            <p class="review-subtitle">
                Pending reviews are shown first. Inside each group, latest comments appear at the top.
            </p>
        </div>

        <div class="review-live-badge">
            ● Moderation Queue Live
        </div>
    </div>

    <div class="review-stats">
        <div class="review-stat-card">
            <div class="review-stat-label">Total</div>
            <div class="review-stat-value">@totalCount</div>
        </div>

        <div class="review-stat-card">
            <div class="review-stat-label">Pending</div>
            <div class="review-stat-value pending">@pendingCount</div>
        </div>

        <div class="review-stat-card">
            <div class="review-stat-label">Approved</div>
            <div class="review-stat-value approved">@approvedCount</div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="review-alert success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="review-alert error">@TempData["ErrorMessage"]</div>
    }

    <div class="review-toolbar">
        <div class="review-toolbar-left">
            <div class="review-toolbar-title">Latest Review Stream</div>
            <div class="review-toolbar-note">Use the filters below to focus on moderation.</div>
        </div>

        <div class="review-filter-group">
            <button type="button" class="review-filter-btn active" data-filter="all">All</button>
            <button type="button" class="review-filter-btn" data-filter="pending">Pending</button>
            <button type="button" class="review-filter-btn" data-filter="approved">Approved</button>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="review-list" id="reviewList">
            @foreach (var item in Model)
            {
                var initials = string.Join("",
                item.NameSurname
                .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                .Take(2)
                .Select(x => x[0].ToString().ToUpper()));

                var statusClass = item.Status ? "approved" : "pending";
                var statusText = item.Status ? "Approved" : "Pending";

                <div class="review-card" data-status="@statusClass">
                    <div class="review-card-top">
                        <div class="review-user">
                            <div class="review-avatar">@initials</div>

                            <div>
                                <div class="review-user-name">@item.NameSurname</div>
                                <div class="review-user-meta">
                                    Review Date: @item.ReviewDate.ToString("dd.MM.yyyy HH:mm")
                                </div>
                            </div>
                        </div>

                        <span class="review-status @statusClass">@statusText</span>
                    </div>

                    <div class="review-rating-row">
                        <div class="review-stars">
                            @for (int i = 1; i <= 5; i++)
                            {
                                @(i <= item.Score ? "★" : "☆")
                            }
                        </div>
                        <div class="review-score-text">@item.Score / 5</div>
                    </div>

                    <div class="review-text">
                        @item.Detail
                    </div>

                    <div class="review-actions">
                        @if (!item.Status)
                        {
                            <form method="post"
                                  asp-action="Approve"
                                  asp-route-id="@item.ReviewId"
                                  class="review-form">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-approve">✔ Approve</button>
                            </form>
                        }

                        <form method="post"
                              asp-action="Delete"
                              asp-route-id="@item.ReviewId"
                              class="review-form"
                              onsubmit="return confirm('Are you sure you want to delete this review?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-delete">Delete</button>
                        </form>
                    </div>
                </div>
            }
        </div>

        <div class="review-empty" id="reviewEmpty" style="display:none;">
            No review found for the selected filter.
        </div>
    }
    else
    {
        <div class="review-empty">
            No reviews found yet.
        </div>
    }
</div>

@section Scripts {
    <script>
        (function () {
            const buttons = document.querySelectorAll('.review-filter-btn');
            const cards = document.querySelectorAll('.review-card');
            const emptyBox = document.getElementById('reviewEmpty');

            if (!buttons.length || !cards.length) return;

            buttons.forEach(button => {
                button.addEventListener('click', function () {
                    const filter = this.dataset.filter;
                    let visibleCount = 0;

                    buttons.forEach(x => x.classList.remove('active'));
                    this.classList.add('active');

                    cards.forEach(card => {
                        const status = card.dataset.status;
                        const shouldShow = filter === 'all' || status === filter;

                        card.style.display = shouldShow ? 'block' : 'none';

                        if (shouldShow) {
                            visibleCount++;
                        }
                    });

                    if (emptyBox) {
                        emptyBox.style.display = visibleCount === 0 ? 'block' : 'none';
                    }
                });
            });
        })();
    </script>
}