@model List<Viatour_Travel.Dtos.ReviewDtos.ResultReviewDto>

@{
    ViewData["Title"] = "Review Management";
    Layout = "~/Views/Shared/_AdminTourLayout.cshtml";
}

<div class="rev-wrap">

    <div class="rev-header">
        <h2>Review Management</h2>
        <p>Approve or delete customer reviews.</p>
    </div>

    <div class="rev-stats">
        <div class="stat-card">
            <p class="stat-label">Total</p>
            <p class="stat-val">@(Model?.Count ?? 0)</p>
        </div>

        <div class="stat-card">
            <p class="stat-label">Pending</p>
            <p class="stat-val warning">@(Model?.Count(x => !x.Status) ?? 0)</p>
        </div>

        <div class="stat-card">
            <p class="stat-label">Approved</p>
            <p class="stat-val success">@(Model?.Count(x => x.Status) ?? 0)</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="rev-list">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                var initials = string.Join("",
                item.NameSurname.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                .Take(2)
                .Select(w => w[0].ToString().ToUpper()));

                <div class="rev-card">
                    <div class="rev-card-top">
                        <div class="rev-meta">
                            <div class="avatar">@initials</div>
                            <div>
                                <p class="rev-name">@item.NameSurname</p>
                                <p class="rev-date">@item.ReviewDate.ToString("dd.MM.yyyy")</p>
                            </div>
                        </div>

                        @if (item.Status)
                        {
                            <span class="badge badge-approved">Approved</span>
                        }
                        else
                        {
                            <span class="badge badge-pending">Pending</span>
                        }
                    </div>

                    <div class="stars">
                        @for (int i = 0; i < 5; i++)
                        {
                            if (i < item.Score)
                            {
                                <span class="star filled">★</span>
                            }
                            else
                            {
                                <span class="star empty">★</span>
                            }
                        }
                        <span class="score-num">@item.Score/5</span>
                    </div>

                    <p class="rev-comment">
                        @item.Detail
                    </p>

                    <div class="rev-actions">
                        @if (!item.Status)
                        {
                            <form method="post" action="/AdminReview/Approve">
                                <input type="hidden" name="id" value="@item.ReviewId" />
                                <button type="submit" class="btn btn-approve">✔ Approve</button>
                            </form>
                        }

                        <form method="post"
                              action="/AdminReview/Delete"
                              onsubmit="return confirm('Are you sure you want to delete this review?')">
                            <input type="hidden" name="id" value="@item.ReviewId" />
                            <button type="submit" class="btn btn-delete">🗑 Delete</button>
                        </form>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-info">No reviews found yet.</div>
        }
    </div>
</div>

<style>
    .rev-wrap {
        padding: 1.5rem;
        font-family: inherit;
    }

    .rev-header {
        margin-bottom: 1.5rem;
    }

        .rev-header h2 {
            font-size: 20px;
            font-weight: 500;
            margin: 0 0 4px;
        }

        .rev-header p {
            font-size: 13px;
            color: #6b7280;
            margin: 0;
        }

    .rev-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
        margin-bottom: 1.5rem;
    }

    .stat-card {
        background: #f9fafb;
        border-radius: 10px;
        padding: 14px 16px;
        border: 1px solid #e5e7eb;
    }

    .stat-label {
        font-size: 12px;
        color: #6b7280;
        margin: 0 0 6px;
    }

    .stat-val {
        font-size: 22px;
        font-weight: 500;
        margin: 0;
        color: #111;
    }

        .stat-val.warning {
            color: #d97706;
        }

        .stat-val.success {
            color: #059669;
        }

    .rev-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .rev-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 16px 18px;
    }

    .rev-card-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 10px;
    }

    .rev-meta {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #dbeafe;
        color: #1d4ed8;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 500;
        flex-shrink: 0;
    }

    .rev-name {
        font-size: 14px;
        font-weight: 500;
        margin: 0 0 3px;
    }

    .rev-date {
        font-size: 12px;
        color: #9ca3af;
        margin: 0;
    }

    .badge {
        font-size: 11px;
        font-weight: 500;
        padding: 3px 10px;
        border-radius: 999px;
    }

    .badge-pending {
        background: #fef3c7;
        color: #92400e;
    }

    .badge-approved {
        background: #d1fae5;
        color: #065f46;
    }

    .stars {
        display: flex;
        align-items: center;
        gap: 2px;
        margin-bottom: 8px;
    }

    .star {
        font-size: 14px;
    }

        .star.filled {
            color: #f59e0b;
        }

        .star.empty {
            color: #d1d5db;
        }

    .score-num {
        font-size: 12px;
        color: #6b7280;
        margin-left: 6px;
    }

    .rev-comment {
        font-size: 13px;
        color: #4b5563;
        line-height: 1.6;
        margin: 0 0 12px;
    }

    .rev-actions {
        display: flex;
        gap: 8px;
        padding-top: 12px;
        border-top: 1px solid #f3f4f6;
        flex-wrap: wrap;
    }

        .rev-actions form {
            margin: 0;
        }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        font-weight: 500;
        padding: 6px 14px;
        border-radius: 8px;
        border: 1px solid;
        cursor: pointer;
        transition: background 0.15s;
        background: transparent;
    }

    .btn-approve {
        border-color: #6ee7b7;
        color: #065f46;
    }

        .btn-approve:hover {
            background: #d1fae5;
        }

    .btn-delete {
        border-color: #fca5a5;
        color: #991b1b;
    }

        .btn-delete:hover {
            background: #fee2e2;
        }

    .alert {
        border-radius: 10px;
        padding: 12px 14px;
        margin-bottom: 14px;
        font-size: 13px;
        border: 1px solid;
    }

    .alert-success {
        background: #ecfdf5;
        color: #065f46;
        border-color: #a7f3d0;
    }

    .alert-danger {
        background: #fef2f2;
        color: #991b1b;
        border-color: #fecaca;
    }

    .alert-info {
        background: #eff6ff;
        color: #1e40af;
        border-color: #bfdbfe;
    }

    @@media (max-width: 768px) {
        .rev-stats {
            grid-template-columns: 1fr;
        }

        .rev-card-top {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>