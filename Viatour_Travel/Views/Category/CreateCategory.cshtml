@model CreateCategoryDtos
@{
    Layout = null;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">Add New Category</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="mb-3">
                            <label asp-for="CategoryName" class="form-label font-weight-bold">Category Name</label>
                            <input type="text" asp-for="CategoryName" class="form-control" placeholder="Example:Electronic" />
                            <span asp-validation-for="CategoryName" class="text-danger small"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-info text-white">
                                <i class="bi bi-save"></i> Save Category
                            </button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-muted small">
                    <a asp-action="Index" class="text-decoration-none">← Back To List</a>
                </div>
            </div>
        </div>
    </div>
</div>