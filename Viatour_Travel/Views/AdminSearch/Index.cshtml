@model Viatour_Travel.Dtos.AdminSearchDtos.ResultAdminSearchDto

@{
    ViewData["Title"] = "Search Results";
    Layout = "~/Views/Shared/_AdminTourLayout.cshtml";
}

@section Styles {
    <style>
        .search-page {
            padding: 32px;
            background: #f7f8fc;
            min-height: 100vh;
        }

        .search-header {
            margin-bottom: 24px;
        }

        .search-title {
            margin: 0 0 8px;
            font-size: 32px;
            font-weight: 800;
            color: #111827;
        }

        .search-subtitle {
            margin: 0;
            color: #6b7280;
            font-size: 14px;
        }

        .search-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 18px;
        }

        .search-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 22px;
            padding: 22px;
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
        }

        .search-card-title {
            font-size: 20px;
            font-weight: 800;
            margin: 0 0 18px;
            color: #111827;
        }

        .search-item {
            display: block;
            text-decoration: none;
            color: inherit;
            border: 1px solid #eef2f7;
            border-radius: 16px;
            padding: 16px;
            margin-bottom: 12px;
            background: #fbfcfe;
            transition: .2s ease;
        }

            .search-item:hover {
                background: #fff;
                transform: translateY(-1px);
                box-shadow: 0 10px 18px rgba(15, 23, 42, 0.05);
            }

        .search-item-top {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            align-items: start;
            margin-bottom: 8px;
        }

        .search-item-title {
            font-size: 15px;
            font-weight: 800;
            color: #111827;
        }

        .search-item-subtitle {
            font-size: 13px;
            color: #6b7280;
            margin-top: 4px;
        }

        .search-item-description {
            font-size: 13px;
            color: #4b5563;
            line-height: 1.6;
        }

        .search-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 82px;
            padding: 7px 10px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 800;
            background: #f3f4f6;
            color: #111827;
        }

        .empty-box {
            background: #fff;
            border: 1px dashed #d1d5db;
            border-radius: 22px;
            padding: 32px;
            text-align: center;
            color: #6b7280;
        }

        @@media (max-width: 992px) {
            .search-grid {
                grid-template-columns: 1fr;
            }

            .search-page {
                padding: 20px;
            }
        }
    </style>
}

<div class="search-page">
    <div class="search-header">
        <h1 class="search-title">Search Results</h1>
        <p class="search-subtitle">
            Query: <strong>@(string.IsNullOrWhiteSpace(Model.Query) ? "-" : Model.Query)</strong>
        </p>
    </div>

    @if (string.IsNullOrWhiteSpace(Model.Query))
    {
        <div class="empty-box">Type a keyword in the admin search box to start searching.</div>
    }
    else
    {
        <div class="search-grid">
            <div class="search-card">
                <h2 class="search-card-title">Tours</h2>
                @if (Model.Tours.Any())
                {
                    @foreach (var item in Model.Tours)
                    {
                        <a href="@item.ResultUrl" class="search-item">
                            <div class="search-item-top">
                                <div>
                                    <div class="search-item-title">@item.Title</div>
                                    <div class="search-item-subtitle">@item.Subtitle</div>
                                </div>
                                <span class="search-badge">@item.StatusText</span>
                            </div>
                            <div class="search-item-description">@item.Description</div>
                        </a>
                    }
                }
                else
                {
                    <div class="empty-box">No tour result found.</div>
                }
            </div>

            <div class="search-card">
                <h2 class="search-card-title">Reservations</h2>
                @if (Model.Reservations.Any())
                {
                    @foreach (var item in Model.Reservations)
                    {
                        <a href="@item.ResultUrl" class="search-item">
                            <div class="search-item-top">
                                <div>
                                    <div class="search-item-title">@item.Title</div>
                                    <div class="search-item-subtitle">@item.Subtitle</div>
                                </div>
                                <span class="search-badge">@item.StatusText</span>
                            </div>
                            <div class="search-item-description">@item.Description</div>
                        </a>
                    }
                }
                else
                {
                    <div class="empty-box">No reservation result found.</div>
                }
            </div>

            <div class="search-card">
                <h2 class="search-card-title">Reviews</h2>
                @if (Model.Reviews.Any())
                {
                    @foreach (var item in Model.Reviews)
                    {
                        <a href="@item.ResultUrl" class="search-item">
                            <div class="search-item-top">
                                <div>
                                    <div class="search-item-title">@item.Title</div>
                                    <div class="search-item-subtitle">@item.Subtitle</div>
                                </div>
                                <span class="search-badge">@item.StatusText</span>
                            </div>
                            <div class="search-item-description">@item.Description</div>
                        </a>
                    }
                }
                else
                {
                    <div class="empty-box">No review result found.</div>
                }
            </div>

            <div class="search-card">
                <h2 class="search-card-title">Categories</h2>
                @if (Model.Categories.Any())
                {
                    @foreach (var item in Model.Categories)
                    {
                        <a href="@item.ResultUrl" class="search-item">
                            <div class="search-item-top">
                                <div>
                                    <div class="search-item-title">@item.Title</div>
                                    <div class="search-item-subtitle">@item.Subtitle</div>
                                </div>
                                <span class="search-badge">@item.StatusText</span>
                            </div>
                            <div class="search-item-description">@item.Description</div>
                        </a>
                    }
                }
                else
                {
                    <div class="empty-box">No category result found.</div>
                }
            </div>
        </div>
    }
</div>