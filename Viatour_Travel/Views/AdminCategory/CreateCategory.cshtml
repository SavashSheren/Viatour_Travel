@model Viatour_Travel.Dtos.CategoryDtos.CreateCategoryDto

@{
    ViewData["Title"] = "Create Category";
    Layout = "~/Views/Shared/_AdminTourLayout.cshtml";
}

@section Styles {
    <style>
        .cat-form-root {
            padding: 32px;
            max-width: 900px;
        }

        .cat-form-breadcrumb {
            font-size: 13px;
            color: #6b7280;
            margin-bottom: 18px;
        }

        .cat-form-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 20px;
            padding: 28px;
            box-shadow: 0 8px 24px rgba(17, 24, 39, 0.05);
        }

        .cat-form-title {
            font-size: 28px;
            font-weight: 800;
            color: #111827;
            margin: 0 0 8px;
        }

        .cat-form-subtitle {
            font-size: 14px;
            color: #6b7280;
            margin-bottom: 26px;
        }

        .form-group {
            margin-bottom: 22px;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            font-size: 14px;
            font-weight: 700;
            color: #111827;
        }

        .form-control {
            width: 100%;
            border: 1px solid #d1d5db;
            border-radius: 12px;
            padding: 14px 16px;
            font-size: 14px;
            outline: none;
            transition: .2s ease;
        }

            .form-control:focus {
                border-color: #111827;
                box-shadow: 0 0 0 4px rgba(17, 24, 39, 0.08);
            }

        .form-check {
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .form-check input {
                width: 18px;
                height: 18px;
            }

        .text-danger {
            display: block;
            margin-top: 8px;
            font-size: 13px;
            color: #dc2626;
        }

        .form-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 28px;
        }

        .btn-save,
        .btn-back {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 140px;
            border-radius: 12px;
            padding: 12px 18px;
            font-size: 14px;
            font-weight: 700;
            text-decoration: none;
            border: none;
            cursor: pointer;
            transition: .2s ease;
        }

        .btn-save {
            background: #111827;
            color: #fff;
        }

        .btn-back {
            background: #f3f4f6;
            color: #111827;
        }

        @@media (max-width: 900px) {
            .cat-form-root {
                padding: 20px;
            }
        }
    </style>
}

<div class="cat-form-root">
    <div class="cat-form-breadcrumb">
        Admin <span>›</span> <span>Categories</span> <span>›</span> <span>Create</span>
    </div>

    <div class="cat-form-card">
        <h1 class="cat-form-title">Create Category</h1>
        <div class="cat-form-subtitle">Add a new category for tours.</div>

        <form asp-controller="AdminCategory" asp-action="CreateCategory" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="CategoryName" class="form-label">Category Name</label>
                <input asp-for="CategoryName" class="form-control" placeholder="Enter category name" />
                <span asp-validation-for="CategoryName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Status</label>
                <div class="form-check">
                    <input asp-for="CategoryStatus" />
                    <label asp-for="CategoryStatus">Active</label>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save">Save Category</button>
                <a asp-controller="AdminCategory" asp-action="Index" class="btn-back">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}