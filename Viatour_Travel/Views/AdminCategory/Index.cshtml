@model List<Viatour_Travel.Dtos.CategoryDtos.ResultCategoryDto>

@{
    ViewData["Title"] = "Categories";
    Layout = "~/Views/Shared/_AdminTourLayout.cshtml";

    var totalCount = Model?.Count ?? 0;
    var activeCount = Model?.Count(x => x.CategoryStatus) ?? 0;
    var passiveCount = totalCount - activeCount;
}

@section Styles {
    <style>
        .cat-root {
            padding: 32px;
        }

        .cat-breadcrumb {
            font-size: 13px;
            color: #6b7280;
            margin-bottom: 18px;
        }

        .cat-page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            margin-bottom: 28px;
            flex-wrap: wrap;
        }

        .cat-page-title {
            font-size: 30px;
            font-weight: 800;
            color: #111827;
            margin: 0;
        }

        .cat-page-subtitle {
            margin: 6px 0 0;
            color: #6b7280;
            font-size: 14px;
        }

        .btn-accent {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #111827;
            color: #fff;
            text-decoration: none;
            border: none;
            border-radius: 12px;
            padding: 12px 18px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            transition: .2s ease;
        }

            .btn-accent:hover {
                opacity: .92;
            }

        .cat-stats {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 18px;
            margin-bottom: 28px;
        }

        .cat-stat-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 14px;
            box-shadow: 0 8px 24px rgba(17, 24, 39, 0.05);
        }

        .cat-stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            background: #f3f4f6;
        }

        .cat-stat-num {
            font-size: 24px;
            font-weight: 800;
            color: #111827;
        }

        .cat-stat-label {
            font-size: 13px;
            color: #6b7280;
            margin-top: 2px;
        }

        .cat-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 8px 24px rgba(17, 24, 39, 0.05);
        }

        .cat-table-wrap {
            overflow-x: auto;
        }

        .cat-table {
            width: 100%;
            border-collapse: collapse;
        }

            .cat-table thead th {
                background: #f9fafb;
                color: #374151;
                font-size: 13px;
                font-weight: 700;
                text-align: left;
                padding: 16px 18px;
                border-bottom: 1px solid #e5e7eb;
            }

            .cat-table tbody td {
                padding: 18px;
                font-size: 14px;
                color: #111827;
                border-bottom: 1px solid #f3f4f6;
                vertical-align: middle;
            }

        .cat-name {
            font-weight: 700;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 90px;
            padding: 8px 12px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 700;
        }

        .status-active {
            background: #ecfdf5;
            color: #065f46;
        }

        .status-passive {
            background: #fef2f2;
            color: #991b1b;
        }

        .cat-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .btn-edit,
        .btn-delete {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 90px;
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 13px;
            font-weight: 700;
            text-decoration: none;
            border: none;
            cursor: pointer;
            transition: .2s ease;
        }

        .btn-edit {
            background: #eff6ff;
            color: #1d4ed8;
        }

            .btn-edit:hover {
                background: #dbeafe;
            }

        .btn-delete {
            background: #fef2f2;
            color: #b91c1c;
        }

            .btn-delete:hover {
                background: #fee2e2;
            }

        .empty-state {
            padding: 44px 24px;
            text-align: center;
            color: #6b7280;
        }

        .temp-success {
            background: #ecfdf5;
            color: #065f46;
            border: 1px solid #a7f3d0;
            border-radius: 14px;
            padding: 14px 16px;
            margin-bottom: 20px;
            font-size: 14px;
            font-weight: 600;
        }

        @@media (max-width: 900px) {
            .cat-root {
                padding: 20px;
            }

            .cat-stats {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="cat-root">
    <div class="cat-breadcrumb">
        Admin <span>›</span> <span>Categories</span>
    </div>

    <div class="cat-page-header">
        <div>
            <h1 class="cat-page-title">Category Management</h1>
            <p class="cat-page-subtitle">Manage tour categories from a single operational screen.</p>
        </div>

        <a asp-controller="AdminCategory" asp-action="CreateCategory" class="btn-accent">
            + New Category
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="temp-success">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="cat-stats">
        <div class="cat-stat-card">
            <div class="cat-stat-icon">📁</div>
            <div>
                <div class="cat-stat-num">@totalCount</div>
                <div class="cat-stat-label">Total Categories</div>
            </div>
        </div>

        <div class="cat-stat-card">
            <div class="cat-stat-icon">✅</div>
            <div>
                <div class="cat-stat-num">@activeCount</div>
                <div class="cat-stat-label">Active Categories</div>
            </div>
        </div>

        <div class="cat-stat-card">
            <div class="cat-stat-icon">⛔</div>
            <div>
                <div class="cat-stat-num">@passiveCount</div>
                <div class="cat-stat-label">Passive Categories</div>
            </div>
        </div>
    </div>

    <div class="cat-card">
        <div class="cat-table-wrap">
            <table class="cat-table">
                <thead>
                    <tr>
                        <th>Category Name</th>
                        <th>Status</th>
                        <th style="width:220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="cat-name">@item.CategoryName</div>
                                </td>
                                <td>
                                    @if (item.CategoryStatus)
                                    {
                                        <span class="status-badge status-active">Active</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-passive">Passive</span>
                                    }
                                </td>
                                <td>
                                    <div class="cat-actions">
                                        <a asp-controller="AdminCategory"
                                           asp-action="UpdateCategory"
                                           asp-route-id="@item.CategoryId"
                                           class="btn-edit">
                                            Edit
                                        </a>

                                        <form asp-controller="AdminCategory"
                                              asp-action="DeleteCategory"
                                              asp-route-id="@item.CategoryId"
                                              method="post"
                                              onsubmit="return confirm('Are you sure you want to delete this category?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-delete">
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3">
                                <div class="empty-state">
                                    No category records found yet.
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>