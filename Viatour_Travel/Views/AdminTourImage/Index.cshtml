@model List<Viatour_Travel.Dtos.TourImageDtos.ResultTourImageDto>

@{
    ViewData["Title"] = "Tour Image Gallery";
    Layout = "~/Views/Shared/_AdminTourLayout.cshtml";
    var tourId = ViewBag.TourId as string;
}

<div class="container-fluid pt-4 px-4">
    <div class="bg-light rounded p-4">

        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h4 class="mb-1">Tour Image Gallery</h4>
                <p class="mb-0 text-muted">Manage tour images for selected tour.</p>
            </div>
            <a href="/AdminTour/TourList" class="btn btn-secondary">
                Back to Tour List
            </a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Upload New Images</h5>

                <form method="post" asp-controller="AdminTourImage" asp-action="Upload" enctype="multipart/form-data">
                    <input type="hidden" name="TourId" value="@tourId" />

                    <div class="mb-3">
                        <label class="form-label">Select Images</label>
                        <input type="file" name="Images" class="form-control" multiple accept="image/*" />
                    </div>

                    <button type="submit" class="btn btn-primary">
                        Upload Images
                    </button>
                </form>
            </div>
        </div>


        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-3">Current Images</h5>

                @if (Model != null && Model.Any())
                {
                    <div class="row g-4">
                        @foreach (var item in Model)
                        {
                            <div class="col-md-4 col-lg-3">
                                <div class="card h-100 border-0 shadow-sm">
                                    <img src="@item.ImageUrl"
                                         class="card-img-top"
                                         alt="Tour Image"
                                         style="height:220px; object-fit:cover;" />

                                    <div class="card-body d-flex flex-column">
                                        <p class="small text-muted mb-3" style="word-break:break-all;">
                                            @item.ImageUrl
                                        </p>

                                        <form method="post" action="/AdminTourImage/Delete" class="mt-auto">
                                            <input type="hidden" name="id" value="@item.TourImageId" />
                                            <input type="hidden" name="tourId" value="@tourId" />
                                            <button type="submit"
                                                    class="btn btn-danger w-100"
                                                    onclick="return confirm('Are you sure you want to delete this image?')">
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-info mb-0">
                        No images found for this tour.
                    </div>
                }
            </div>
        </div>
    </div>
</div>